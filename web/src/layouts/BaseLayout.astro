---
import "@/styles/global.css";
import type { Locale } from "@/consts";
import { FEATURES } from "@/consts";
import { dir } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import Seo from "@/components/Seo.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Newsletter from "@/components/Newsletter.astro";
import BusinessPattern from "@/components/BusinessPattern.astro";
import PatternDefs from "@/components/PatternDefs.astro";
import Cart from "@/components/Cart.astro";
import EngagementPopup from "@/components/EngagementPopup.astro";

interface Props {
  lang: Locale;
  title: string;
  description?: string;
  video?: { src: string; thumbnailUrl?: string };
  ogType?: string;
  /** Suppress the global newsletter band (e.g. pages that embed it inline). */
  hideNewsletter?: boolean;
  /** Full-height pages (e.g. the video viewer): tighten the gap before the
   *  newsletter band so the email box is reached as soon as you scroll past. */
  immersive?: boolean;
  /** Video slug for this page — counted toward the engagement popup trigger. */
  trackVideoId?: string;
}

const {
  lang,
  title,
  description,
  video,
  ogType,
  hideNewsletter = false,
  immersive = false,
  trackVideoId,
} = Astro.props;
const direction = dir(lang);
const t = useTranslations(lang);

// Cloudflare Web Analytics beacon token (public, not a secret). Set
// PUBLIC_CF_BEACON_TOKEN in the Pages build env to turn on privacy-friendly,
// cookieless traffic stats; when unset (e.g. local dev) the beacon is omitted.
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

// X (Twitter) Pixel IDs for ad conversion tracking. Supports multiple pixels
// for separate Ads Manager accounts. Set PUBLIC_X_PIXEL_IDS as comma-separated
// values (e.g. "pixel1,pixel2") in Cloudflare Pages env; omitted when unset.
const xPixelIds = (import.meta.env.PUBLIC_X_PIXEL_IDS ?? "")
  .split(",")
  .map((id: string) => id.trim())
  .filter(Boolean);
---

<!doctype html>
<html lang={lang} dir={direction}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <Seo
      title={title}
      description={description}
      lang={lang}
      video={video}
      ogType={ogType}
    />
    {
      beaconToken && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: beaconToken })}
        />
      )
    }
    {
      xPixelIds.length > 0 && (
        <script
          is:inline
          data-x-pixel-ids={xPixelIds.join(",")}
          set:html={`
            !function(e,t,n,s,u,a){e.twq||(s=e.twq=function(){s.exe?s.exe.apply(s,arguments):s.queue.push(arguments);
            },s.version='1.1',s.queue=[],u=t.createElement(n),u.async=!0,u.src='https://static.ads-twitter.com/uwt.js',
            a=t.getElementsByTagName(n)[0],a.parentNode.insertBefore(u,a))}(window,document,'script');
            ${xPixelIds.map((id: string) => `twq('config', '${id}');`).join("\n            ")}
          `}
        />
      )
    }
    <PatternDefs />
  </head>
  <body class={immersive ? "immersive" : undefined}>
    <a class="skip-link label" href="#main">Skip to content</a>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <div class="bottom-zone business-surface">
      <BusinessPattern />
      {
        !hideNewsletter && (
          <section class="newsletter-band">
            <div class="newsletter-inner">
              <Newsletter lang={lang} disabled={!FEATURES.newsletter} />
            </div>
          </section>
        )
      }
      <Footer lang={lang} />
    </div>
    {FEATURES.shop && <Cart lang={lang} />}
    {
      FEATURES.newsletter && (
        <EngagementPopup lang={lang} trackVideoId={trackVideoId} />
      )
    }
    <script>
      import { captureAttribution } from "@/lib/attribution";
      captureAttribution();
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -999px;
    top: 0;
    background: var(--color-carbon);
    color: var(--color-cream);
    padding: 0.75rem 1rem;
    z-index: 50;
  }
  .skip-link:focus {
    left: 1rem;
  }
  /* Single continuous zone for newsletter + footer with one shared pattern */
  .bottom-zone {
    position: relative;
    margin-top: 6rem;
  }
  :global(body.immersive) .bottom-zone {
    margin-top: 0;
  }
  .newsletter-band {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--bar-line);
  }
  .newsletter-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 4.5rem) 1.5rem;
  }
</style>
