---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { formatDuration, type VideoVariant } from "@/lib/videos";
import ShareBar from "./ShareBar.astro";

interface Props {
  variant: VideoVariant;
  category: "truth" | "myth" | "project";
  tags?: string[];
  lang: Locale;
}
const { variant, category, tags = [], lang } = Astro.props;
const t = useTranslations(lang);
const duration = formatDuration(variant.durationSeconds);
const categoryLabel = t(`category.${category}` as const);

// Split the script into paragraphs for a readable transcript column. Built so a
// future synced-highlight transcript can replace this block without changing
// the surrounding layout.
const paragraphs = (variant.script ?? "")
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<div class="script-panel">
  <div class="head">
    <span class="label">{categoryLabel}</span>
    {duration && <span class="label time">{duration}</span>}
  </div>

  <h1 class="title font-display">{variant.title}</h1>

  {
    paragraphs.length > 0 && (
      <div class="transcript">
        <span class="label transcript-label">{t("video.script")}</span>
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
    )
  }

  {
    tags.length > 0 && (
      <ul class="tags">
        {tags.map((tag) => (
          <li class="label">#{tag}</li>
        ))}
      </ul>
    )
  }

  <hr class="rule" />

  <ShareBar title={variant.title} platforms={variant.platforms} lang={lang} />
</div>

<style>
  .script-panel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .time {
    color: var(--text-muted);
  }
  .title {
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.05;
    margin: 0;
    color: var(--text);
  }
  .transcript {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .transcript-label {
    color: var(--text-muted);
  }
  .transcript p {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text);
  }
  html[dir="rtl"] .transcript p {
    font-size: 1.25rem;
    line-height: 2;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tags li {
    color: var(--text-muted);
  }
  .rule {
    margin: 0.5rem 0 0;
  }
</style>
