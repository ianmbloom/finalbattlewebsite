---
/**
 * Low-contrast decorative background accent. The tiling artwork is generated
 * by the Escher engine in `@/lib/patternTile` and shared across instances via
 * a `:root` custom property (defined once by `<PatternDefs>`); this component
 * just paints that pre-tinted tile and repeats it.
 *
 * Colour is baked into the shared data URI (see patternTile.ts for why a
 * `background-image` SVG must be recoloured at the source). `opacity` is
 * applied here so the same tinted tile can sit at any strength.
 */
import { tileBackgroundSize, tileVarName } from "@/lib/patternTile";
import type { PatternColor } from "@/lib/patternTile";

interface Props {
  color?: PatternColor;
  opacity?: number;
  /** Vertical offset of the tiling, e.g. "-120px" to skip the top fringe. */
  posY?: string;
  class?: string;
}

const {
  color = "canary",
  opacity = 0.06,
  posY = "0",
  class: className = "",
} = Astro.props;

const style = [
  `--pattern-src: var(${tileVarName(color)})`,
  `--pattern-size: ${tileBackgroundSize()}`,
  `--pattern-pos-y: ${posY}`,
  `opacity: ${opacity}`,
].join("; ");
---

<div class:list={["pattern-bg", className]} style={style} aria-hidden="true">
</div>

<style>
  .pattern-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: var(--pattern-src);
    background-repeat: repeat;
    /* One period per repeat unit. */
    background-size: var(--pattern-size);
    background-position: 0 var(--pattern-pos-y, 0);
  }
</style>
