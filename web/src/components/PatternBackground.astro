---
/**
 * Decorative Persian (non-Islamic) tiling ornament used as a low-contrast
 * background accent. The SVG is line art, so we paint it with a palette token
 * via CSS `mask-image` (the source stroke color is irrelevant) and tile it.
 * Purely decorative: never interactive, hidden from assistive tech.
 */
type PaletteColor = "ink" | "sand" | "stone" | "gold" | "crimson";

interface Props {
  src?: string;
  color?: PaletteColor;
  opacity?: number;
  /** Tile size, e.g. "480px". Larger = bigger motif. */
  size?: string;
  class?: string;
}

const {
  src = "/patterns/PatternMatte.svg",
  color = "ink",
  opacity = 0.06,
  size = "480px",
  class: className = "",
} = Astro.props;

const style = [
  `--pattern-src: url('${src}')`,
  `--pattern-size: ${size}`,
  `background-color: var(--color-${color})`,
  `opacity: ${opacity}`,
].join("; ");
---

<div
  class:list={["pattern-bg", className]}
  style={style}
  aria-hidden="true"
>
</div>

<style>
  .pattern-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: var(--pattern-src);
    mask-image: var(--pattern-src);
    -webkit-mask-repeat: repeat;
    mask-repeat: repeat;
    -webkit-mask-size: var(--pattern-size);
    mask-size: var(--pattern-size);
    -webkit-mask-position: center;
    mask-position: center;
  }
</style>
