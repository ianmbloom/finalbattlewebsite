---
/**
 * Decorative Persian (non-Islamic) tiling ornament used as a low-contrast
 * background accent. The SVG is line art, recolored via CSS `mask-image`.
 *
 * The motif's topmost scallop peaks repeat every 144.54 user units. The art
 * is cropped to exactly 8 periods (viewBox width 1156.32) so the peak grid is
 * continuous across the horizontal seam — adjacent tiles meet without a gap
 * and without squishing the motif. Vertical scale is left untouched (lower
 * curves are designed to overlap).
 */
type PaletteColor =
  | "ink"
  | "sand"
  | "stone"
  | "gold"
  | "emerald"
  | "crimson"
  | "rose"
  | "canary";

interface Props {
  src?: string;
  color?: PaletteColor;
  opacity?: number;
  /** Tile width on screen, e.g. "480px". Height follows the SVG aspect. */
  size?: string;
  /** Vertical offset of the tile, e.g. "-120px" to skip the top fringe. */
  posY?: string;
  class?: string;
}

const {
  src = "/patterns/PatternMatte.svg",
  color = "ink",
  opacity = 0.06,
  size = "480px",
  posY = "0",
  class: className = "",
} = Astro.props;

/** Cropped viewBox aspect: height / width = 2005.62 / 1156.32. */
const aspect = 2005.62 / 1156.32;

const style = [
  `--pattern-src: url('${src}')`,
  `--pattern-size: ${size}`,
  `--pattern-aspect: ${aspect}`,
  `--pattern-pos-y: ${posY}`,
  `background-color: var(--color-${color})`,
  `opacity: ${opacity}`,
].join("; ");
---

<div
  class:list={["pattern-bg", className]}
  style={style}
  aria-hidden="true"
>
</div>

<style>
  .pattern-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: var(--pattern-src);
    mask-image: var(--pattern-src);
    -webkit-mask-repeat: repeat;
    mask-repeat: repeat;
    /* Natural aspect (no distortion); width maps to exactly one repeat. */
    -webkit-mask-size:
      var(--pattern-size)
      calc(var(--pattern-size) * var(--pattern-aspect));
    mask-size:
      var(--pattern-size)
      calc(var(--pattern-size) * var(--pattern-aspect));
    -webkit-mask-position: 0 var(--pattern-pos-y, 0);
    mask-position: 0 var(--pattern-pos-y, 0);
  }
</style>
