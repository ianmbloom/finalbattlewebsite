---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import { formatDuration, getVariant, type VideoEntry } from "@/lib/videos";
import Logo from "./Logo.astro";
import PatternBackground from "./PatternBackground.astro";

interface Props {
  lang: Locale;
  featured?: VideoEntry;
}
const { lang, featured } = Astro.props;
const t = useTranslations(lang);

const variant = featured ? getVariant(featured, lang) : undefined;
const featuredHref = featured
  ? localizedPath(`/videos/${featured.id}`, lang)
  : null;
const featuredDuration = formatDuration(variant?.durationSeconds);
const featuredCategory = featured
  ? t(`category.${featured.data.category}` as const)
  : "";
---

<section class:list={["hero", { "has-feature": Boolean(variant) }]}>
  <PatternBackground color="ink" opacity={0.05} size="540px" />

  <div class="hero-grid">
    <div class="copy">
      <span class="mark"><Logo size={72} /></span>
      <h1 class="title font-logo">{t("site.name")}</h1>
      <p class="brand-sub font-display">{t("site.subtitle")}</p>
      <p class="subtitle">
        <span>{t("hero.subtitle.line1")}</span>
        <span>{t("hero.subtitle.line2")}</span>
      </p>
      <div class="ctas">
        <a class="btn-outline" href={localizedPath("/videos", lang)}>
          {t("hero.cta.watch")}
        </a>
        <a class="btn-outline" href={localizedPath("/about", lang)}>
          {t("hero.cta.about")}
        </a>
      </div>
    </div>

    {
      variant && featuredHref && (
        <a class="feature" href={featuredHref} aria-label={variant.title}>
          <div class="feature-thumb">
            {variant.thumbnailUrl ? (
              <img
                src={variant.thumbnailUrl}
                alt={variant.title}
                width="270"
                height="480"
                fetchpriority="high"
              />
            ) : (
              <span class="thumb-fallback label">9:16</span>
            )}
            <span class="feature-badge label">
              {featuredCategory}
              {featuredDuration && <span class="dot"> · {featuredDuration}</span>}
            </span>
          </div>
          <div class="feature-meta">
            <span class="label feature-eyebrow">{t("home.featured")}</span>
            <span class="feature-title font-display">{variant.title}</span>
          </div>
        </a>
      )
    }
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .copy {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .mark {
    color: var(--color-gold);
    animation: fade-in 800ms var(--ease-editorial) both;
  }
  .title {
    font-weight: 400;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: 0.005em;
    margin: 0;
    color: var(--text);
  }
  .brand-sub {
    margin: -0.5rem 0 0;
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    line-height: 1;
    color: var(--color-gold);
  }
  .subtitle {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin: 0.5rem 0 0;
    font-size: 1rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  /* Featured 9:16 video — kept visible within the first viewport. */
  .feature {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: max-content;
    max-width: 100%;
    margin-inline: auto;
  }
  .feature-thumb {
    position: relative;
    aspect-ratio: 9 / 16;
    max-height: 60svh;
    background: #000;
    border: 1px solid var(--line);
    overflow: hidden;
  }
  .feature-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms var(--ease-editorial);
  }
  .feature:hover .feature-thumb img {
    transform: scale(1.02);
  }
  .thumb-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-sand);
  }
  .feature-badge {
    position: absolute;
    top: 0.75rem;
    inset-inline-start: 0.75rem;
    padding: 0.35rem 0.6rem;
    background: color-mix(in srgb, var(--color-obsidian) 72%, transparent);
    color: var(--color-parchment);
    backdrop-filter: blur(2px);
  }
  .feature-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .feature-eyebrow {
    color: var(--color-gold);
  }
  .feature-title {
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1.15;
    color: var(--text);
    transition: color 300ms var(--ease-editorial);
  }
  .feature:hover .feature-title {
    color: var(--color-gold);
  }

  /* Desktop: two columns, sized to sit above the fold. */
  @media (min-width: 900px) {
    .hero.has-feature .hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
      min-height: calc(100svh - 5.5rem);
      padding-block: 2rem;
    }
    .hero.has-feature .feature {
      margin-inline-start: auto;
    }
    .hero.has-feature .feature-thumb {
      max-height: 72svh;
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .mark {
      animation: none;
    }
  }
</style>
