---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { type VideoVariant } from "@/lib/videos";

interface Props {
  variant: VideoVariant;
  lang: Locale;
}
const { variant, lang } = Astro.props;
const t = useTranslations(lang);

// The longer-form background, set as a magazine feature: a drop-capped lead
// paragraph followed by justified body columns.
const paragraphs = (variant.context ?? "")
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter(Boolean);
---

{
  paragraphs.length > 0 && (
    <article class="story">
      <div class="prose font-display">
        <span class="label prose-label">{t("video.context")}</span>
        {paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </article>
  )
}

<style>
  .story {
    display: flex;
    flex-direction: column;
  }
  .prose {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }
  .prose-label {
    color: var(--text-muted);
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
  }
  .prose p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text);
    text-align: justify;
    text-wrap: pretty;
    hyphens: auto;
  }
  /* Drop cap on the opening paragraph for the magazine feel. */
  .prose p:first-of-type::first-letter {
    float: inline-start;
    font-size: 2.8em;
    line-height: 0.84;
    padding-inline-end: 0.08em;
    margin-block-start: 0.06em;
    font-weight: 600;
    color: var(--color-gold);
  }
  html[dir="rtl"] .prose {
    font-family: var(--font-fa);
  }
  html[dir="rtl"] .prose p {
    font-size: 0.9rem;
    line-height: 1.95;
    hyphens: none;
  }
</style>
