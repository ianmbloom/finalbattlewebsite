---
interface Props {
  src: string;
  title: string;
  poster?: string;
  autoplay?: boolean;
}
const { src, title, poster, autoplay = false } = Astro.props;
---

<div class="player">
  <video
    src={src}
    title={title}
    poster={poster}
    controls
    playsinline
    crossorigin="anonymous"
    preload="metadata"
    autoplay={autoplay}
    muted={autoplay}
  ></video>
</div>

<style>
  /* Mobile: full width, aspect-ratio drives height */
  .player {
    width: 100%;
    aspect-ratio: 9 / 16;
    background: #000;
    border: 1px solid var(--line);
    border-radius: 1.5rem;
    overflow: hidden;
  }
  .player video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000;
  }

  /* Desktop: height drives the size, width follows from aspect-ratio.
     --header-h approximates the site header height (padding + content). */
  @media (min-width: 900px) {
    .player {
      height: calc(100dvh - 4rem - 3rem); /* subtract header + column padding */
      width: auto;
      border: none;
    }
  }
</style>
