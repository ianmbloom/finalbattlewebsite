---
interface Props {
  src: string;
  title: string;
  poster?: string;
  autoplay?: boolean;
}
const { src, title, poster, autoplay = false } = Astro.props;
---

<div class="player">
  <video
    src={src}
    title={title}
    poster={poster}
    controls
    playsinline
    preload="metadata"
    autoplay={autoplay}
    muted={autoplay}
  ></video>
</div>

<style>
  /* Mobile: full width, aspect-ratio drives height. The max-width caps the
     portrait frame at the width it reaches in the wide two-column layout
     (height-constrained to the viewport), so it never scales larger than that
     as the window widens — it just centers with margin to spare. */
  .player {
    width: 100%;
    max-width: calc((100dvh - 4rem - 3rem) * 9 / 16);
    aspect-ratio: 9 / 16;
    margin-inline: auto;
    background: #000;
    border: 1px solid var(--line);
    border-radius: 2rem;
    overflow: hidden;
  }
  .player video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000;
  }

  /* Desktop: height drives the size, width follows from aspect-ratio.
     --header-h approximates the site header height (padding + content). */
  @media (min-width: 900px) {
    .player {
      height: calc(100dvh - 4rem - 3rem); /* subtract header + column padding */
      width: auto;
      border: none;
    }
  }
</style>
