---
interface Props {
  src: string;
  title: string;
  poster?: string;
  autoplay?: boolean;
}
const { src, title, poster, autoplay = false } = Astro.props;
---

<div class="player">
  <video
    src={src}
    title={title}
    poster={poster}
    controls
    playsinline
    preload="metadata"
    autoplay={autoplay}
    muted={autoplay}
  ></video>
</div>

<script>
  // Signal "the video is wrapping up" so downstream UI (e.g. the email popup)
  // can surface right as attention naturally releases — not on an arbitrary
  // timer. We fire once, a beat before the final frame, so the handoff feels
  // like part of the ending rather than an interruption over the content.
  const ENDING_LEAD_SECONDS = 2;

  document.querySelectorAll<HTMLVideoElement>(".player video").forEach((video) => {
    let signalled = false;

    const signalEnding = () => {
      if (signalled) return;
      signalled = true;
      document.dispatchEvent(new CustomEvent("fb-video:ending"));
    };

    // Allow re-arming if the viewer scrubs back and watches again.
    video.addEventListener("seeking", () => {
      const remaining = video.duration - video.currentTime;
      if (Number.isFinite(remaining) && remaining > ENDING_LEAD_SECONDS + 1) {
        signalled = false;
      }
    });

    video.addEventListener("timeupdate", () => {
      const remaining = video.duration - video.currentTime;
      if (Number.isFinite(remaining) && remaining <= ENDING_LEAD_SECONDS) {
        signalEnding();
      }
    });

    // Fallback for very short clips or browsers that skip the final tick.
    video.addEventListener("ended", signalEnding);
  });
</script>

<style>
  /* Mobile: full width, aspect-ratio drives height. The max-width caps the
     portrait frame at the width it reaches in the wide two-column layout
     (height-constrained to the viewport), so it never scales larger than that
     as the window widens — it just centers with margin to spare. */
  .player {
    width: 100%;
    max-width: calc((100dvh - 4rem - 3rem) * 9 / 16);
    aspect-ratio: 9 / 16;
    margin-inline: auto;
    background: #000;
    border: 1px solid var(--line);
    border-radius: 2rem;
    overflow: hidden;
  }
  .player video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000;
  }

  /* Desktop: height drives the size, width follows from aspect-ratio.
     --header-h approximates the site header height (padding + content). */
  @media (min-width: 900px) {
    .player {
      height: calc(100dvh - 4rem - 3rem); /* subtract header + column padding */
      width: auto;
      border: none;
    }
  }
</style>
