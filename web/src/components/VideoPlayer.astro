---
interface Props {
  src: string;
  title: string;
  poster?: string;
  autoplay?: boolean;
}
const { src, title, poster, autoplay = false } = Astro.props;
---

<div class="player">
  <video
    src={src}
    title={title}
    poster={poster}
    controls
    playsinline
    crossorigin="anonymous"
    preload="metadata"
    autoplay={autoplay}
    muted={autoplay}
  ></video>
</div>

<style>
  .player {
    position: relative;
    width: 100%;
    /* 9:16 aspect ratio */
    padding-top: 177.78%;
    background: #000;
    border: 1px solid var(--line);
  }
  .player video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000;
  }
</style>
