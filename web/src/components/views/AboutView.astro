---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import { CATEGORY_COLOR, type Category } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Logo from "@/components/Logo.astro";
import BusinessPattern from "@/components/BusinessPattern.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const arrows: { key: Category; body: string }[] = [
  { key: "truth", body: t("about.arrow.truth") },
  { key: "myth", body: t("about.arrow.myth") },
  { key: "project", body: t("about.arrow.project") },
];
---

<BaseLayout lang={lang} title={t("about.title")} description={t("about.lead")}>
  <article class="about">
    <header class="about-head">
      <span class="mark"><Logo size={84} /></span>
      <h1 class="title font-display">{t("about.title")}</h1>
      <p class="lead font-display">{t("about.lead")}</p>
    </header>

    <section class="block">
      <span class="label">{t("about.goal.title")}</span>
      <p>{t("about.goal.body")}</p>
    </section>

    <hr class="rule" />

    <section class="block">
      <span class="label">{t("about.method.title")}</span>
      <p>{t("about.method.body")}</p>
      <ol class="arrows">
        {
          arrows.map((a) => (
            <li style={`border-color:${CATEGORY_COLOR[a.key]}`}>
              <span class="label arrow-cat" style={`color:${CATEGORY_COLOR[a.key]}`}>
                {t(`category.${a.key}` as const)}
              </span>
              <span class="arrow-body">{a.body}</span>
            </li>
          ))
        }
      </ol>
    </section>
  </article>

  <section class="tagline-block business-surface">
    <BusinessPattern />
    <div class="tagline-inner">
      <span class="mark"><Logo size={52} /></span>
      <p class="tagline font-display">{t("site.tagline")}</p>
      <a class="btn-outline-on-bar" href={localizedPath("/videos", lang)}>
        {t("hero.cta.watch")}
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .about-head {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }
  .mark {
    color: var(--color-emerald);
  }
  .title {
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin: 0;
    color: var(--text);
  }
  .lead {
    font-weight: 300;
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.35;
    margin: 0;
    color: var(--text-muted);
  }
  .block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2.5rem 0;
  }
  .block p {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text);
  }
  .arrows {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .arrows li {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-inline-start: 1.25rem;
    border-inline-start: 2px solid var(--color-emerald);
  }
  .arrow-cat {
    color: var(--color-emerald);
  }
  .arrow-body {
    font-size: 1.15rem;
    color: var(--text);
  }
  .rule {
    margin: 0;
  }
  .tagline-block {
    margin-top: 4rem;
  }
  .tagline-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    text-align: center;
  }
  .tagline-block .mark {
    color: var(--bar-accent);
  }
  .tagline {
    font-weight: 300;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin: 0;
    color: var(--bar-text);
  }
</style>
