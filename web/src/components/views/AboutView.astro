---
import type { Locale } from "@/consts";
import { FEATURES } from "@/consts";
import { useTranslations, localizedPath, linkify } from "@/i18n/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BusinessPattern from "@/components/BusinessPattern.astro";
import Newsletter from "@/components/Newsletter.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const helpBody = linkify(t("about.help.body"), {
  launch: {
    href: localizedPath("/videos", lang),
    label: t("link.launch"),
  },
  shop: {
    href: localizedPath("/shop", lang),
    label: t("link.shop"),
  },
  fund: {
    href: localizedPath("/fund", lang),
    label: t("link.fund"),
  },
});
---

<BaseLayout lang={lang} title={t("about.title")} description={t("about.lead")} hideNewsletter>
  <article class="about">
    <div class="about-grid">
      <header class="about-head">
        <h1 class="section-title font-display">{t("about.title")}</h1>
        <p class="prose font-display">{t("about.lead")}</p>
      </header>

      <figure class="mosaic">
        <img
          src="/about/mosaic-flag-bearer.webp"
          alt={t("about.image_alt")}
          width="1400"
          height="1875"
          loading="eager"
        />
      </figure>

      <div class="about-body">
        <section class="block">
          <h2 class="section-title font-display">{t("about.vision.title")}</h2>
          <p class="prose font-display">{t("about.vision.body")}</p>
        </section>

        <hr class="rule" />

        <section class="block">
          <h2 class="section-title font-display">{t("about.mission.title")}</h2>
          <p class="prose font-display">{t("about.mission.body")}</p>
        </section>

        <hr class="rule" />

        <section class="block">
          <h2 class="section-title font-display">{t("about.help.title")}</h2>
          <p class="prose font-display" set:html={helpBody} />
        </section>

        <p class="about-abbr">{t("abbr.note")}</p>

        <section class="signup business-surface">
          <BusinessPattern />
          <div class="signup-inner">
            <Newsletter lang={lang} compact disabled={!FEATURES.newsletter} />
          </div>
        </section>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    max-width: 1040px;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .about-head {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .section-title {
    margin: 0;
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 1.9rem);
    line-height: 1.2;
    color: var(--text);
  }
  .prose {
    margin: 0;
    font-weight: 400;
    font-size: clamp(1.15rem, 1.8vw, 1.35rem);
    line-height: 1.7;
    color: var(--text);
  }
  .mosaic {
    margin: 0;
    display: flex;
    justify-content: center;
  }
  .mosaic img {
    width: 100%;
    max-width: 420px;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--line);
    box-shadow: 0 18px 40px -24px rgba(0, 0, 0, 0.45);
  }
  @media (min-width: 880px) {
    .about-grid {
      grid-template-columns: minmax(0, 1fr) 340px;
      column-gap: 3.5rem;
      row-gap: 0;
      align-items: start;
    }
    .about-head {
      grid-column: 1;
      grid-row: 1;
    }
    .about-body {
      grid-column: 1;
      grid-row: 2;
    }
    .mosaic {
      grid-column: 2;
      grid-row: 1 / span 2;
      position: sticky;
      top: 6rem;
      align-self: start;
    }
  }
  .block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2.5rem 0;
  }
  .signup {
    position: relative;
    overflow: hidden;
    margin-top: 0.5rem;
    border: 1px solid var(--bar-line);
    border-radius: 6px;
  }
  .signup-inner {
    position: relative;
    z-index: 1;
    padding: 1.75rem 1.5rem;
  }
  .rule {
    margin: 0;
  }
  .about-abbr {
    margin: 0 0 1.5rem;
    max-width: 60ch;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-muted);
    font-style: italic;
  }
  .prose :global(.prose-link) {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-emerald) 45%, transparent);
    text-underline-offset: 0.15em;
    transition: color 300ms var(--ease-editorial);
  }
  .prose :global(.prose-link:hover) {
    color: var(--color-emerald);
  }
</style>
