---
import {
  resolveVideoSrc,
  SITE_URL,
  FEATURES,
  ENABLED_LOCALES,
  type Locale,
} from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import { getVariant, getVideoCredit, getBoostTier, type VideoEntry } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoPlayer from "@/components/VideoPlayer.astro";
import RepostMenu from "@/components/RepostMenu.astro";
import Transcript from "@/components/Transcript.astro";
import StoryPanel from "@/components/StoryPanel.astro";
import LaunchThisVideo from "@/components/LaunchThisVideo.astro";

interface Props {
  entry: VideoEntry;
  lang: Locale;
}
const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const variant = getVariant(entry, lang)!;
const videoSrc = resolveVideoSrc(variant.videoSrc);
const creditLine = getVideoCredit(variant, t("video.narratedBy"));

// Absolute URL of this video page, used to pre-fill the Reddit submit form.
const pageUrl = new URL(localizedPath(`/videos/${entry.id}`, lang), SITE_URL)
  .href;

// Sister video: the same entry in the other language. When that variant exists
// we link to it; until then we show a muted "available soon" note in its place.
const otherLang: Locale = lang === "en" ? "fa" : "en";
// Only surface the cross-language link when the other locale is actually
// exposed in the served UI (see ENABLED_LOCALES).
const otherLangEnabled = ENABLED_LOCALES.includes(otherLang);
const hasSibling = Boolean(getVariant(entry, otherLang));
const siblingHref = localizedPath(`/videos/${entry.id}`, otherLang);
const siblingLabel = lang === "en" ? t("video.alsoInFa") : t("video.alsoInEn");
const soonLabel = lang === "en" ? t("video.faSoon") : t("video.enSoon");
const boostTier = getBoostTier(entry);
---

<BaseLayout
  lang={lang}
  title={variant.title}
  description={variant.script?.slice(0, 180)}
  video={{ src: videoSrc, thumbnailUrl: variant.thumbnailUrl }}
  trackVideoId={entry.id}
  immersive
>
  <div class="viewer">
    <div class="video-col">
      <VideoPlayer
        src={videoSrc}
        poster={variant.thumbnailUrl}
        title={variant.title}
      />
    </div>

    <div class="story-col">
      <div class="title-block">
        <h1 class="video-title font-display">{variant.title}</h1>
        <p class="narrator">{creditLine}</p>
      </div>
      {
        otherLangEnabled &&
          (hasSibling ? (
            <a class="sister-link" href={siblingHref}>
              {siblingLabel}
            </a>
          ) : (
            <span class="sister-soon">{soonLabel}</span>
          ))
      }
      {
        FEATURES.boost && (
          <LaunchThisVideo videoSlug={entry.id} boostTier={boostTier} locale={lang} />
        )
      }
      <RepostMenu
        title={variant.title}
        platforms={variant.platforms}
        pageUrl={pageUrl}
        lang={lang}
      />
      <Transcript variant={variant} lang={lang} />
      <StoryPanel variant={variant} lang={lang} />
      <a class="back" href={localizedPath("/videos", lang)}>
        ← {t("video.back")}
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  /* Mobile: single column, video first then content */
  .viewer {
    display: flex;
    flex-direction: column;
  }

  .video-col {
    background: var(--bg);
  }

  .story-col {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding: 1.75rem 1.5rem 4rem;
  }

  .video-title {
    font-weight: 300;
    font-size: clamp(2.1rem, 3.4vw, 3rem);
    line-height: 1.05;
    margin: 0;
    color: var(--text);
  }

  .title-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }

  .narrator {
    margin: 0;
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    opacity: 0.75;
  }

  .back {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    transition: color 300ms var(--ease-editorial);
    margin-top: 0.5rem;
  }
  .back:hover {
    color: var(--color-emerald);
  }

  .sister-link,
  .sister-soon {
    display: inline-block;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-top: -0.75rem;
  }
  .sister-link {
    transition: color 300ms var(--ease-editorial);
  }
  .sister-link:hover {
    color: var(--color-emerald);
  }
  .sister-soon {
    font-style: italic;
    opacity: 0.8;
  }

  /* Desktop: locked side-by-side. Video column is exactly as wide as the 9:16
     frame at full viewport height; story column takes the rest and scrolls
     independently. Nothing scrolls the video off screen. */
  @media (min-width: 900px) {
    .viewer {
      flex-direction: row;
      height: calc(100dvh - 5rem);
      overflow: hidden;
    }

    .video-col {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 1.25rem;
    }

    .story-col {
      flex: 1;
      min-width: 0;
      overflow-y: auto;
      /* Let the scroll chain to the page when this column bottoms out, so the
         reader continues into the newsletter/footer instead of dead-ending. */
      overscroll-behavior: auto;
      scrollbar-width: thin;
      padding: 2.5rem 3rem 2rem;
      gap: 2rem;
    }
  }
</style>
