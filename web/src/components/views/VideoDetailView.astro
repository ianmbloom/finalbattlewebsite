---
import { resolveVideoSrc, type Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import { getVariant, type VideoEntry } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoPlayer from "@/components/VideoPlayer.astro";
import Transcript from "@/components/Transcript.astro";
import StoryPanel from "@/components/StoryPanel.astro";

interface Props {
  entry: VideoEntry;
  lang: Locale;
}
const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const variant = getVariant(entry, lang)!;
const videoSrc = resolveVideoSrc(variant.videoSrc);
---

<BaseLayout
  lang={lang}
  title={variant.title}
  description={variant.script?.slice(0, 180)}
  video={{ src: videoSrc, thumbnailUrl: variant.thumbnailUrl }}
>
  <div class="viewer">
    <div class="video-col">
      <VideoPlayer
        src={videoSrc}
        poster={variant.thumbnailUrl}
        title={variant.title}
      />
    </div>

    <div class="story-col">
      <a class="back label" href={localizedPath("/videos", lang)}>
        ← {t("video.back")}
      </a>
      <Transcript variant={variant} lang={lang} />
      <StoryPanel
        variant={variant}
        category={entry.data.category}
        tags={entry.data.tags}
        lang={lang}
      />
    </div>
  </div>
</BaseLayout>

<style>
  /* Mobile: single column, video first then content */
  .viewer {
    display: flex;
    flex-direction: column;
  }

  .video-col {
    background: #000;
  }

  .story-col {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding: 2rem 1.5rem 5rem;
  }

  .back {
    display: inline-block;
    color: var(--text-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .back:hover {
    color: var(--color-emerald);
  }

  /* Desktop: locked side-by-side. Video column is exactly as wide as the 9:16
     frame at full viewport height; story column takes the rest and scrolls
     independently. Nothing scrolls the video off screen. */
  @media (min-width: 900px) {
    .viewer {
      flex-direction: row;
      height: calc(100dvh - 5rem);
      overflow: hidden;
    }

    .video-col {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .story-col {
      flex: 1;
      min-width: 0;
      overflow-y: auto;
      overscroll-behavior: contain;
      scrollbar-width: thin;
      padding: 3.5rem 4rem 6rem;
      gap: 3.5rem;
    }
  }
</style>
