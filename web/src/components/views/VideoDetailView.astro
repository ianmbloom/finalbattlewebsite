---
import { resolveVideoSrc, type Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import { getVariant, type VideoEntry } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoPlayer from "@/components/VideoPlayer.astro";
import Transcript from "@/components/Transcript.astro";
import StoryPanel from "@/components/StoryPanel.astro";

interface Props {
  entry: VideoEntry;
  lang: Locale;
}
const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const variant = getVariant(entry, lang)!;
const videoSrc = resolveVideoSrc(variant.videoSrc);
---

<BaseLayout
  lang={lang}
  title={variant.title}
  description={variant.script?.slice(0, 180)}
  video={{ src: videoSrc, thumbnailUrl: variant.thumbnailUrl }}
>
  <article class="viewer">
    <a class="back label" href={localizedPath("/videos", lang)}>
      ← {t("video.back")}
    </a>

    <div class="columns">
      <div class="video-col">
        <VideoPlayer
          src={videoSrc}
          poster={variant.thumbnailUrl}
          title={variant.title}
        />
        <Transcript variant={variant} lang={lang} />
      </div>

      <div class="story-col">
        <StoryPanel
          variant={variant}
          category={entry.data.category}
          tags={entry.data.tags}
          lang={lang}
        />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .viewer {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 0;
  }
  .back {
    display: inline-block;
    color: var(--text-muted);
    margin-bottom: 2rem;
    transition: color 300ms var(--ease-editorial);
  }
  .back:hover {
    color: var(--color-emerald);
  }
  .columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .video-col {
    /* 9:16 video kept narrow so it doesn't dominate on wide screens */
    max-width: 380px;
    width: 100%;
    margin-inline: auto;
  }
  .story-col {
    min-width: 0;
  }
  @media (min-width: 900px) {
    .columns {
      grid-template-columns: minmax(300px, 0.8fr) 1.2fr;
      gap: 4rem;
      align-items: start;
    }
    .video-col {
      margin-inline: 0;
      /* Video + transcript stay pinned and scroll on their own; the article
         column scrolls with the page, so the two move independently. */
      position: sticky;
      top: 1.5rem;
      max-height: calc(100dvh - 3rem);
      overflow-y: auto;
      overscroll-behavior: contain;
      scrollbar-width: thin;
      padding-block-end: 0.5rem;
    }
    .story-col {
      min-width: 0;
      padding-block: 0.5rem 5rem;
    }
  }
</style>
