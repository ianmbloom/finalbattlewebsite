---
import type { Locale } from "@/consts";
import { FEATURES } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getProducts } from "@/lib/products";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BusinessPattern from "@/components/BusinessPattern.astro";
import ProductCard from "@/components/ProductCard.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const products = await getProducts();
---

<BaseLayout lang={lang} title={t("shop.title")} description={t("shop.intro")}>
  <section class="shop-band business-surface">
    <BusinessPattern />
    <div class="shop-band-inner">
      <h1 class="title font-display">{t("shop.title")}</h1>
      <p class="intro">{t("shop.intro")}</p>
    </div>
  </section>

  <section class="shop">
    {!FEATURES.shop && <p class="soon-banner">{t("common.soon")}</p>}
    {
      products.length > 0 ? (
        <div class="grid">
          {products.map((entry) => <ProductCard lang={lang} entry={entry} />)}
        </div>
      ) : (
        <p class="empty label">{t("shop.empty")}</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .shop-band {
    border-bottom: 1px solid var(--bar-line);
  }
  .shop-band-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 5rem) 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .shop-band .title {
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    margin: 0;
    color: var(--bar-text);
  }
  .shop-band .intro {
    margin: 0;
    max-width: 48ch;
    font-size: 1.1rem;
    color: var(--bar-muted);
  }
  .shop {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 0;
  }
  .soon-banner {
    margin: 0 0 1.75rem;
    padding: 0.75rem 1rem;
    text-align: center;
    border: 1px dashed var(--line-strong);
    border-radius: 4px;
    color: var(--text-muted);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  html[dir="rtl"] .soon-banner {
    text-transform: none;
    letter-spacing: 0.04em;
  }
  .grid {
    display: grid;
    column-gap: 1.5rem;
    row-gap: 2.25rem;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .empty {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
  }
</style>
