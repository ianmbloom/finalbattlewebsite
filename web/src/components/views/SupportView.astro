---
import type { Locale } from "@/consts";
import { FEATURES } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BusinessPattern from "@/components/BusinessPattern.astro";
import SupportCTA from "@/components/SupportCTA.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const shopHref = localizedPath("/shop", lang);
---

<BaseLayout lang={lang} title={t("support.title")} description={t("support.lead")}>
  <section class="support-band business-surface">
    <BusinessPattern />
    <div class="support-band-inner">
      <h1 class="title font-display">{t("support.title")}</h1>
      <p class="lead">{t("support.lead")}</p>
    </div>
  </section>

  <section class="support-body">
    <div class="block donate">
      <SupportCTA lang={lang} variant="band" disabled={!FEATURES.donations} />
    </div>

    <hr class="rule" />

    <div class="block shop">
      <div class="copy">
        <h2 class="title font-display">
          {t("support.shop.title")}
          {!FEATURES.shop && <span class="soon">{t("common.soon")}</span>}
        </h2>
        <p class="body">{t("support.shop.body")}</p>
      </div>
      {
        FEATURES.shop ? (
          <a class="btn-outline shop-cta" href={shopHref}>{t("support.shop.cta")}</a>
        ) : (
          <span class="btn-outline shop-cta is-disabled" aria-disabled="true">
            {t("support.shop.cta")}
          </span>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .support-band {
    border-bottom: 1px solid var(--bar-line);
  }
  .support-band-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 5rem) 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .support-band .title {
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    margin: 0;
    color: var(--bar-text);
  }
  .support-band .lead {
    margin: 0;
    max-width: 52ch;
    font-size: 1.1rem;
    color: var(--bar-muted);
  }
  .support-body {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .shop .copy {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .shop .title {
    margin: 0;
    font-weight: 400;
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    line-height: 1.1;
    color: var(--text);
  }
  .shop .body {
    margin: 0;
    max-width: 52ch;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .shop-cta {
    align-self: flex-start;
    cursor: pointer;
  }
  .shop-cta.is-disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }
  .soon {
    display: inline-block;
    margin-inline-start: 0.6rem;
    vertical-align: middle;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    color: var(--text-muted);
  }
  html[dir="rtl"] .soon {
    text-transform: none;
    letter-spacing: 0;
  }
  .rule {
    margin: 0;
  }
</style>
