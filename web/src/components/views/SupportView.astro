---
import type { Locale } from "@/consts";
import { FEATURES } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SupportCTA from "@/components/SupportCTA.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const shopHref = localizedPath("/shop", lang);
---

<BaseLayout lang={lang} title={t("support.title")} description={t("support.lead")}>
  <section class="support">
    <h1 class="support-lead font-display">{t("support.lead")}</h1>

    <div class="block fund">
      <SupportCTA lang={lang} variant="band" disabled={!FEATURES.donations} />
    </div>

    <hr class="rule" />

    <div class="block shop">
      <div class="actions">
        {
          FEATURES.shop ? (
            <a class="btn-outline shop-cta" href={shopHref}>{t("support.shop.title")}</a>
          ) : (
            <span class="btn-outline shop-cta is-disabled" aria-disabled="true">
              {t("support.shop.title")}
            </span>
          )
        }
        {!FEATURES.shop && <span class="soon">{t("common.soon")}</span>}
      </div>
      <p class="body">{t("support.shop.body")}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .support {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 3.5rem) 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .support-lead {
    margin: 0;
    max-width: 32ch;
    font-weight: 300;
    font-size: clamp(1.5rem, 3.2vw, 2.2rem);
    line-height: 1.25;
    color: var(--text);
  }
  .block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .shop .body {
    margin: 0;
    max-width: 52ch;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .shop-cta {
    align-self: flex-start;
    cursor: pointer;
  }
  .shop-cta.is-disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }
  .soon {
    display: inline-block;
    margin-inline-start: 0.6rem;
    vertical-align: middle;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    color: var(--text-muted);
  }
  html[dir="rtl"] .soon {
    text-transform: none;
    letter-spacing: 0;
  }
  .rule {
    margin: 0;
  }
</style>
