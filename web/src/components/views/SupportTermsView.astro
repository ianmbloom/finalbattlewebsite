---
/**
 * The trust page behind the Launch button. One coherent message: a lead that
 * states the whole deal (launching is patronage that buys reach and funds the
 * next video), then how we spend it, then a link to fund everything.
 */
import type { Locale } from "@/consts";
import { useTranslations, localizedPath, linkify } from "@/i18n/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const fundHref = localizedPath("/fund", lang);
const fundLink = { fund: { href: fundHref, label: t("link.fund") } };

const sections = [
  { title: t("terms.spend.title"), body: t("terms.spend.body") },
  {
    title: t("terms.fund.title"),
    body: linkify(t("terms.fund.body"), fundLink),
    html: true,
  },
];
---

<BaseLayout lang={lang} title={t("terms.title")} description={t("terms.lead")}>
  <section class="terms">
    <h1 class="terms-title font-display">{t("terms.title")}</h1>
    <p class="terms-lead font-display">{t("terms.lead")}</p>
    {
      sections.map((s) => (
        <div class="terms-block">
          <h2 class="terms-heading font-display">{s.title}</h2>
          {s.html ? (
            <p class="terms-body" set:html={s.body} />
          ) : (
            <p class="terms-body">{s.body}</p>
          )}
        </div>
      ))
    }
  </section>
</BaseLayout>

<style>
  .terms {
    max-width: 680px;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4.5rem) 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .terms-title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.05;
    color: var(--text);
  }
  .terms-lead {
    margin: 0;
    max-width: 54ch;
    font-weight: 400;
    font-size: clamp(1.2rem, 2.2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text);
  }
  .terms-block {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .terms-heading {
    margin: 0;
    font-weight: 400;
    font-size: clamp(1.3rem, 2.6vw, 1.7rem);
    line-height: 1.15;
    color: var(--text);
  }
  .terms-body {
    margin: 0;
    max-width: 60ch;
    line-height: 1.65;
    color: var(--text-muted);
  }
  .terms-body :global(.prose-link) {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-emerald) 45%, transparent);
    text-underline-offset: 0.15em;
    transition: color 300ms var(--ease-editorial);
  }
  .terms-body :global(.prose-link:hover) {
    color: var(--color-emerald);
  }
</style>
