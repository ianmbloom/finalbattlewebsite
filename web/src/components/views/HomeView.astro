---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getVideosForLocale } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoGrid from "@/components/VideoGrid.astro";
import PromoteBand from "@/components/PromoteBand.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const videos = await getVideosForLocale(lang);
---

<BaseLayout lang={lang} title={t("site.name")} description={t("home.statement.p1")}>
  <section class="statement hero-band">
    <div class="statement-inner">
      <p class="lead font-display">{t("home.statement.p1")} {t("home.statement.p2")}</p>
      <p class="call font-display">{t("home.statement.p3")}</p>
    </div>
  </section>

  <section class="series">
    <div class="series-head">
      <h2 class="series-title font-display">{t("videos.title")}</h2>
      <hr class="rule" />
    </div>
    <VideoGrid videos={videos} lang={lang} />
  </section>

  <PromoteBand lang={lang} />
</BaseLayout>

<style>
  .statement-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3.5rem) 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .lead {
    margin: 0;
    font-weight: 300;
    font-size: clamp(0.95rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    color: var(--text);
  }
  .call {
    margin: 0.25rem 0 0;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(0.9rem, 1.3vw, 1.1rem);
    line-height: 1.4;
    color: var(--color-gold);
  }
  .series {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 1.5rem 0;
  }
  .series-head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .series-title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    line-height: 1.1;
    color: var(--text);
  }
  .series-head .rule {
    margin: 0;
  }
</style>
