---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getShortVideosForLocale, getLongVideosForLocale } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoGrid from "@/components/VideoGrid.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const videos = await getShortVideosForLocale(lang);
const longVideos = await getLongVideosForLocale(lang);

const channels = {
  en: [
    { name: "X", url: "https://x.com/seeuinfreeiran" },
    { name: "Instagram", url: "https://www.instagram.com/seeuinfreeiran" },
    { name: "YouTube", url: "https://www.youtube.com/@seeuinfreeiran" },
    { name: "LinkedIn", url: "https://www.linkedin.com/company/final-battle-for-iran-39585941a" },
  ],
  fa: [
    { name: "X", url: "https://x.com/ta_didar_azadi" },
    { name: "Instagram", url: "https://instagram.com/ta_didar_azadi" },
    { name: "YouTube", url: "https://youtube.com/@ta_didar_azadi" },
    { name: "LinkedIn", url: "https://linkedin.com/company/ta_didar_azadi" },
  ],
};
const socialChannels = channels[lang];
const riseIranHref =
  lang === "fa" ? "https://iranopasmigirim.com/" : "https://iranopasmigirim.com/en";

// Obscure the outbound link in served HTML (restored client-side), matching
// the footer's social links.
function obfuscate(str: string): string {
  return str.split("").reverse().join("");
}
---

<BaseLayout lang={lang} title={t("site.name")} description={t("home.statement.p1")}>
  <section class="statement hero-band">
    <div class="statement-inner">
      <p class="arrow font-display">{t("promote.title")}</p>
      {
        t("home.hero.sub")
          .split("\n\n")
          .map((para) => <p class="call font-display">{para}</p>)
      }
    </div>
  </section>

  <p class="rise-link font-display">
    <a class="obf-link" data-u={obfuscate(riseIranHref)} href="#" target="_blank" rel="noopener noreferrer">{t("social.riseIran")}</a>
  </p>

  <section class="channels font-display">
    <span class="channels-label">{t("social.follow")}</span>
    {socialChannels.map((ch, i) => (
      <>
        {i > 0 && <span class="channels-dot" aria-hidden="true">·</span>}
        <a class="obf-link" data-u={obfuscate(ch.url)} href="#" target="_blank" rel="noopener noreferrer">{ch.name}</a>
      </>
    ))}
  </section>

  <section class="series">
    <div class="series-head">
      <h2 class="series-title font-display">{t("videos.title")}</h2>
      <hr class="rule" />
    </div>
    <VideoGrid videos={videos} lang={lang} />
  </section>

  {
    longVideos.length > 0 && (
      <section class="series series-long">
        <div class="series-head">
          <h2 class="series-title font-display">{t("videos.longForm.title")}</h2>
          <hr class="rule" />
        </div>
        <VideoGrid videos={longVideos} lang={lang} />
      </section>
    )
  }
</BaseLayout>

<script>
  document.querySelectorAll<HTMLAnchorElement>(".obf-link").forEach((link) => {
    const obfuscated = link.dataset.u;
    if (obfuscated) {
      link.href = obfuscated.split("").reverse().join("");
    }
  });
</script>

<style>
  .statement-inner {
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(1rem, 2vw, 1.5rem) 1.5rem clamp(0.75rem, 1.5vw, 1rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }
  .arrow {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.1;
    color: var(--text);
  }
  .call {
    margin: 0;
    max-width: 52ch;
    font-weight: 300;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.4;
    color: var(--text);
  }
  .series {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0;
  }
  .series-long {
    margin-top: 1rem;
    padding-bottom: 4rem;
  }
  .series-head {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .series-title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    line-height: 1.1;
    color: var(--text);
  }
  .series-head .rule {
    margin: 0;
  }
  .channels {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--muted);
  }
  .channels-label {
    color: var(--text);
  }
  .channels-dot {
    color: var(--muted);
  }
  .channels a {
    color: var(--muted);
    transition: color 300ms var(--ease-editorial);
  }
  .channels a:hover {
    color: var(--accent);
  }
  .rise-link {
    margin: 0;
    padding: 0.75rem 1.5rem 0;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 300;
  }
  .rise-link a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
    transition: color 300ms var(--ease-editorial);
  }
  .rise-link a::after {
    content: " \2197";
  }
  html[dir="rtl"] .rise-link a::after {
    content: " \2196";
  }
  .rise-link a:hover {
    color: var(--text);
  }
</style>
