---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getVideosForLocale } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoGrid from "@/components/VideoGrid.astro";
import PatternBackground from "@/components/PatternBackground.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const videos = await getVideosForLocale(lang);
---

<BaseLayout lang={lang} title={t("site.name")} description={t("home.statement.p1")}>
  <section class="statement hero-band">
    <PatternBackground color="rose" opacity={0.28} size="360px" />
    <div class="statement-inner">
      <p class="lead font-display">{t("home.statement.p1")}</p>
      <p class="lead font-display">{t("home.statement.p2")}</p>
      <p class="call font-display">{t("home.statement.p3")}</p>
    </div>
  </section>

  <section class="series">
    <div class="series-head">
      <h2 class="series-title font-display">{t("videos.title")}</h2>
      <hr class="rule" />
    </div>
    <VideoGrid videos={videos} lang={lang} />
  </section>
</BaseLayout>

<style>
  .statement-inner {
    max-width: 60rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 9vw, 7rem) 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .lead {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.35;
    color: var(--text);
  }
  .call {
    margin: 0.25rem 0 0;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    line-height: 1.3;
    color: var(--color-gold);
  }
  .series {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .series-head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .series-title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.1;
    color: var(--text);
  }
  .series-head .rule {
    margin: 0;
  }
</style>
