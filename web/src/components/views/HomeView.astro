---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getVideosForLocale } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoGrid from "@/components/VideoGrid.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const videos = await getVideosForLocale(lang);
---

<BaseLayout lang={lang} title={t("site.name")} description={t("home.statement.p1")}>
  <section class="statement hero-band">
    <div class="statement-inner">
      <p class="lead font-display">{t("home.statement.p1")}</p>
      <p class="arrow font-display">{t("promote.title")}</p>
      <p class="call font-display">{t("promote.body")}</p>
    </div>
  </section>

  <section class="series">
    <div class="series-head">
      <h2 class="series-title font-display">{t("videos.title")}</h2>
      <hr class="rule" />
    </div>
    <VideoGrid videos={videos} lang={lang} />
  </section>
</BaseLayout>

<style>
  .statement-inner {
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4.5rem) 1.5rem clamp(2rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
    text-align: center;
  }
  .lead {
    margin: 0;
    max-width: 52ch;
    font-weight: 300;
    font-size: clamp(1.05rem, 1.8vw, 1.4rem);
    line-height: 1.5;
    color: var(--text);
  }
  .arrow {
    margin: 0.5rem 0;
    font-weight: 300;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.1;
    color: var(--text);
  }
  .call {
    margin: 0;
    max-width: 52ch;
    font-weight: 300;
    font-size: clamp(1.05rem, 1.8vw, 1.4rem);
    line-height: 1.5;
    color: var(--text);
  }
  .series {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 1.5rem 0;
  }
  .series-head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .series-title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    line-height: 1.1;
    color: var(--text);
  }
  .series-head .rule {
    margin: 0;
  }
</style>
