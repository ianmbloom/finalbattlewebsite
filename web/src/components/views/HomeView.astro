---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getShortVideosForLocale, getLongVideosForLocale } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoGrid from "@/components/VideoGrid.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const videos = await getShortVideosForLocale(lang);
const longVideos = await getLongVideosForLocale(lang);
---

<BaseLayout lang={lang} title={t("site.name")} description={t("home.statement.p1")}>
  <section class="statement hero-band">
    <div class="statement-inner">
      <p class="arrow font-display">{t("promote.title")}</p>
      {
        t("home.hero.sub")
          .split("\n\n")
          .map((para) => <p class="call font-display">{para}</p>)
      }
    </div>
  </section>

  <section class="series">
    <div class="series-head">
      <h2 class="series-title font-display">{t("videos.title")}</h2>
      <hr class="rule" />
    </div>
    <VideoGrid videos={videos} lang={lang} />
  </section>

  {
    longVideos.length > 0 && (
      <section class="series series-long">
        <div class="series-head">
          <h2 class="series-title font-display">{t("videos.longForm.title")}</h2>
          <hr class="rule" />
        </div>
        <VideoGrid videos={longVideos} lang={lang} />
      </section>
    )
  }
</BaseLayout>

<style>
  .statement-inner {
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(1.75rem, 3.5vw, 3rem) 1.5rem clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }
  .arrow {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.1;
    color: var(--text);
  }
  .call {
    margin: 0;
    max-width: 52ch;
    font-weight: 300;
    font-size: clamp(1.05rem, 1.8vw, 1.4rem);
    line-height: 1.5;
    color: var(--text);
  }
  .series {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 1.5rem 0;
  }
  .series-long {
    margin-top: 1rem;
    padding-bottom: 4rem;
  }
  .series-head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .series-title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    line-height: 1.1;
    color: var(--text);
  }
  .series-head .rule {
    margin: 0;
  }
</style>
