---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getVideosForLocale } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FilterBar from "@/components/FilterBar.astro";
import VideoGrid from "@/components/VideoGrid.astro";
import BusinessPattern from "@/components/BusinessPattern.astro";
import PromoteBand from "@/components/PromoteBand.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const videos = await getVideosForLocale(lang);
---

<BaseLayout lang={lang} title={t("videos.title")} description={t("videos.intro")}>
  <section class="library-band business-surface">
    <BusinessPattern />
    <div class="library-band-inner">
      <h1 class="title font-display">{t("videos.title")}</h1>
      <p class="intro">{t("videos.intro")}</p>
    </div>
  </section>

  <section class="library">
    <FilterBar lang={lang} />
    <VideoGrid videos={videos} lang={lang} />
    <p class="empty label" data-empty hidden>{t("videos.empty")}</p>
  </section>

  <PromoteBand lang={lang} showCta={false} />
</BaseLayout>

<style>
  .library-band {
    border-bottom: 1px solid var(--bar-line);
  }
  .library-band-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 5rem) 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .library-band .title {
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    margin: 0;
    color: var(--bar-text);
  }
  .library-band .intro {
    margin: 0;
    max-width: 48ch;
    font-size: 1.1rem;
    color: var(--bar-muted);
  }
  .library {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .empty {
    margin-top: 1rem;
    text-align: center;
    color: var(--text-muted);
  }
</style>
