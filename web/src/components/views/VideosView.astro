---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getVideosForLocale } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FilterBar from "@/components/FilterBar.astro";
import VideoGrid from "@/components/VideoGrid.astro";
import PromoteBand from "@/components/PromoteBand.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const videos = await getVideosForLocale(lang);
---

<BaseLayout lang={lang} title={t("videos.title")} description={t("videos.intro")}>
  <section class="library">
    <FilterBar lang={lang} />
    <VideoGrid videos={videos} lang={lang} />
    <p class="empty label" data-empty hidden>{t("videos.empty")}</p>
  </section>

  <PromoteBand lang={lang} showCta={false} />
</BaseLayout>

<style>
  .library {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 3.5rem) 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .empty {
    margin-top: 1rem;
    text-align: center;
    color: var(--text-muted);
  }
</style>
