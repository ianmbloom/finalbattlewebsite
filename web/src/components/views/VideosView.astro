---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { getShortVideosForLocale, getLongVideosForLocale } from "@/lib/videos";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FilterBar from "@/components/FilterBar.astro";
import VideoGrid from "@/components/VideoGrid.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const videos = await getShortVideosForLocale(lang);
const longVideos = await getLongVideosForLocale(lang);
---

<BaseLayout lang={lang} title={t("videos.title")} description={t("videos.intro")}>
  <section class="library">
    <div class="series-block">
      <div class="series-head">
        <h2 class="series-title font-display">{t("videos.title")}</h2>
        <hr class="rule" />
      </div>
      <FilterBar lang={lang} />
      <VideoGrid videos={videos} lang={lang} />
      <p class="empty label" data-empty hidden>{t("videos.empty")}</p>
    </div>

    {
      longVideos.length > 0 && (
        <div class="series-block series-long">
          <div class="series-head">
            <h2 class="series-title font-display">{t("videos.longForm.title")}</h2>
            <hr class="rule" />
          </div>
          <VideoGrid videos={longVideos} lang={lang} />
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .library {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 3.5rem) 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .series-block {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .series-long {
    padding-bottom: 3rem;
  }
  .series-head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .series-title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    line-height: 1.1;
    color: var(--text);
  }
  .series-head .rule {
    margin: 0;
  }
  .empty {
    margin-top: 1rem;
    text-align: center;
    color: var(--text-muted);
  }
</style>
