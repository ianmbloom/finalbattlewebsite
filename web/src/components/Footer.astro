---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import LionSun from "./LionSun.astro";
import PatternBackground from "./PatternBackground.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <PatternBackground color="gold" opacity={0.12} size="420px" />
  <div class="inner">
    <span class="mark"><LionSun size={40} /></span>
    <p class="tagline font-display">{t("site.tagline")}</p>
    <div class="meta label">
      <a href={localizedPath("/", lang)}>{t("site.name")}</a>
      <span aria-hidden="true">·</span>
      <span>{t("footer.rights")}</span>
      <span aria-hidden="true">·</span>
      <span>© {year}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    margin-top: 6rem;
    border-top: 1px solid var(--line);
  }
  .inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }
  .mark {
    color: var(--color-gold);
  }
  .tagline {
    font-weight: 300;
    font-size: 1.75rem;
    color: var(--text);
    margin: 0;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
  .meta a {
    color: var(--text-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .meta a:hover {
    color: var(--color-gold);
  }
</style>
