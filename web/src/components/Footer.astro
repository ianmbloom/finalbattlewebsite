---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import Logo from "./Logo.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const socialChannels = [
  { name: "YouTube", url: "https://www.youtube.com/@seeuinfreeiran/shorts" },
  { name: "X", url: "https://x.com/seeuinfreeiran" },
  { name: "Instagram", url: "https://www.instagram.com/seeuinfreeiran" },
  { name: "LinkedIn", url: "https://www.linkedin.com/company/final-battle-for-iran-39585941a" },
];

function obfuscate(str: string): string {
  return str.split("").reverse().join("");
}
---

<footer class="site-footer">
  <div class="inner">
    <span class="mark"><Logo size={52} /></span>
    <p class="tagline font-display">{t("site.tagline")}</p>
    <nav class="links label" aria-label="Footer">
      <a href={localizedPath("/videos", lang)}>{t("nav.videos")}</a>
      <a href={localizedPath("/fund", lang)}>{t("nav.support")}</a>
      <a href={localizedPath("/about", lang)}>{t("nav.about")}</a>
    </nav>
    <nav class="social label" aria-label="Social channels">
      {socialChannels.map((ch) => (
        <a
          class="social-link"
          data-u={obfuscate(ch.url)}
          href="#"
          target="_blank"
          rel="noopener noreferrer"
        >
          {ch.name}
        </a>
      ))}
    </nav>
    <div class="meta label">
      <span>© {year} {t("site.name")}</span>
      <span aria-hidden="true">·</span>
      <button
        type="button"
        class="copy-email"
        data-email="finalbattlefilms@gmail.com"
      >
        <span class="copy-email-text">finalbattlefilms@gmail.com</span>
        <span class="copy-email-status" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    /* Margin handled by parent .bottom-zone when inside BaseLayout */
  }
  .inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }
  .mark {
    color: var(--bar-accent);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .links a {
    color: var(--bar-text);
    transition: color 300ms var(--ease-editorial);
  }
  .links a:hover {
    color: var(--bar-accent);
  }
  .links .disabled {
    color: var(--bar-muted);
    opacity: 0.5;
    cursor: not-allowed;
  }
  .social {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .social a {
    color: var(--bar-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .social a:hover {
    color: var(--bar-accent);
  }
  .tagline {
    font-weight: 300;
    font-size: 1.75rem;
    color: var(--bar-text);
    margin: 0;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--bar-muted);
  }
  .meta a {
    color: var(--bar-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .meta a:hover {
    color: var(--bar-accent);
  }
  .copy-email {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0;
    border: 0;
    background: none;
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    color: var(--bar-muted);
    cursor: pointer;
    transition: color 300ms var(--ease-editorial);
  }
  .copy-email:hover {
    color: var(--bar-accent);
  }
  .copy-email-status {
    color: var(--bar-accent);
    opacity: 0;
    transition: opacity 200ms var(--ease-editorial);
  }
  .copy-email.copied .copy-email-status {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>(".social-link").forEach((link) => {
    const obfuscated = link.dataset.u;
    if (obfuscated) {
      link.href = obfuscated.split("").reverse().join("");
    }
  });

  document.querySelectorAll<HTMLButtonElement>(".copy-email").forEach((btn) => {
    const status = btn.querySelector<HTMLElement>(".copy-email-status");
    let timer: number | undefined;
    btn.addEventListener("click", async () => {
      const email = btn.dataset.email;
      if (!email) return;
      try {
        await navigator.clipboard.writeText(email);
      } catch {
        const range = document.createRange();
        const textEl = btn.querySelector(".copy-email-text");
        if (textEl) {
          range.selectNodeContents(textEl);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
      if (status) status.textContent = "Copied";
      btn.classList.add("copied");
      window.clearTimeout(timer);
      timer = window.setTimeout(() => {
        btn.classList.remove("copied");
        if (status) status.textContent = "";
      }, 2000);
    });
  });
</script>
