---
import type { Locale } from "@/consts";
import { FEATURES } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import Logo from "./Logo.astro";
import BusinessPattern from "./BusinessPattern.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer business-surface">
  <BusinessPattern />
  <div class="inner">
    <span class="mark"><Logo size={52} /></span>
    <p class="tagline font-display">{t("site.tagline")}</p>
    <nav class="links label" aria-label="Footer">
      <a href={localizedPath("/videos", lang)}>{t("nav.videos")}</a>
      {
        FEATURES.shop ? (
          <a href={localizedPath("/shop", lang)}>{t("nav.shop")}</a>
        ) : (
          <span class="disabled" aria-disabled="true">{t("nav.shop")}</span>
        )
      }
      <a href={localizedPath("/support", lang)}>{t("nav.support")}</a>
      <a href={localizedPath("/about", lang)}>{t("nav.about")}</a>
    </nav>
    <div class="meta label">
      <a href={localizedPath("/", lang)}>{t("site.name")}</a>
      <span aria-hidden="true">·</span>
      <span>{t("footer.rights")}</span>
      <span aria-hidden="true">·</span>
      <span>© {year}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
  }
  .inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }
  .mark {
    color: var(--bar-accent);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .links a {
    color: var(--bar-text);
    transition: color 300ms var(--ease-editorial);
  }
  .links a:hover {
    color: var(--bar-accent);
  }
  .links .disabled {
    color: var(--bar-muted);
    opacity: 0.5;
    cursor: not-allowed;
  }
  .tagline {
    font-weight: 300;
    font-size: 1.75rem;
    color: var(--bar-text);
    margin: 0;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--bar-muted);
  }
  .meta a {
    color: var(--bar-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .meta a:hover {
    color: var(--bar-accent);
  }
</style>
