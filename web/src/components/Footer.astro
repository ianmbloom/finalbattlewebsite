---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import Logo from "./Logo.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="inner">
    <span class="mark"><Logo size={52} /></span>
    <p class="tagline font-display">{t("site.tagline")}</p>
    <nav class="links label" aria-label="Footer">
      <a href={localizedPath("/videos", lang)}>{t("nav.videos")}</a>
      <a href={localizedPath("/fund", lang)}>{t("nav.support")}</a>
      <a href={localizedPath("/about", lang)}>{t("nav.about")}</a>
    </nav>
    <div class="meta label">
      <a href={localizedPath("/", lang)}>{t("site.name")}</a>
      <span aria-hidden="true">·</span>
      <span>{t("footer.rights")}</span>
      <span aria-hidden="true">·</span>
      <a href={localizedPath("/support-terms", lang)}>{t("footer.terms")}</a>
      <span aria-hidden="true">·</span>
      <span>© {year}</span>
    </div>
    <p class="contact label">
      <span class="contact-label">Contact</span>
      <button
        type="button"
        class="copy-email"
        data-email="finalbattlefilms@gmail.com"
      >
        <span class="copy-email-text">finalbattlefilms@gmail.com</span>
        <span class="copy-email-status" aria-hidden="true"></span>
      </button>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    /* Margin handled by parent .bottom-zone when inside BaseLayout */
  }
  .inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }
  .mark {
    color: var(--bar-accent);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .links a {
    color: var(--bar-text);
    transition: color 300ms var(--ease-editorial);
  }
  .links a:hover {
    color: var(--bar-accent);
  }
  .links .disabled {
    color: var(--bar-muted);
    opacity: 0.5;
    cursor: not-allowed;
  }
  .tagline {
    font-weight: 300;
    font-size: 1.75rem;
    color: var(--bar-text);
    margin: 0;
  }
  .contact {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.5rem;
    margin: 0;
    color: var(--bar-muted);
  }
  .contact-label {
    text-transform: uppercase;
  }
  .copy-email {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0;
    border: 0;
    background: none;
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    color: var(--bar-text);
    cursor: pointer;
    transition: color 300ms var(--ease-editorial);
  }
  .copy-email:hover {
    color: var(--bar-accent);
  }
  .copy-email-status {
    color: var(--bar-accent);
    opacity: 0;
    transition: opacity 200ms var(--ease-editorial);
  }
  .copy-email.copied .copy-email-status {
    opacity: 1;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--bar-muted);
  }
  .meta a {
    color: var(--bar-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .meta a:hover {
    color: var(--bar-accent);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-email").forEach((btn) => {
    const status = btn.querySelector<HTMLElement>(".copy-email-status");
    let timer: number | undefined;
    btn.addEventListener("click", async () => {
      const email = btn.dataset.email;
      if (!email) return;
      try {
        await navigator.clipboard.writeText(email);
      } catch {
        const range = document.createRange();
        const textEl = btn.querySelector(".copy-email-text");
        if (textEl) {
          range.selectNodeContents(textEl);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
      if (status) status.textContent = "Copied";
      btn.classList.add("copied");
      window.clearTimeout(timer);
      timer = window.setTimeout(() => {
        btn.classList.remove("copied");
        if (status) status.textContent = "";
      }, 2000);
    });
  });
</script>
