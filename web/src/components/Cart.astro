---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div id="fb-cart" data-locale={lang} hidden aria-hidden="true">
  <div data-cart-backdrop class="cart-backdrop"></div>
  <aside class="cart-panel" role="dialog" aria-modal="true" aria-label={t("cart.title")}>
    <header class="cart-head">
      <h2 class="cart-title font-display">{t("cart.title")}</h2>
      <button type="button" data-cart-close aria-label={t("cart.close")} class="cart-x">
        <span aria-hidden="true">&times;</span>
      </button>
    </header>

    <div data-cart-items class="cart-items"></div>

    <p data-cart-empty hidden class="cart-empty">{t("cart.empty")}</p>

    <footer data-cart-footer class="cart-foot">
      <div class="cart-subtotal-row">
        <span>{t("cart.subtotal")}</span>
        <span data-cart-subtotal>$0.00</span>
      </div>
      <p class="cart-ship label">{t("cart.shipping_note")}</p>
      <p data-cart-error hidden class="cart-err label">{t("cart.error")}</p>
      <button type="button" data-cart-checkout class="cart-checkout">{t("cart.checkout")}</button>
      <button type="button" data-cart-close class="btn-outline cart-continue">{t("cart.continue")}</button>
    </footer>
  </aside>
</div>

<script>
  interface CartItem {
    sku: string;
    format: "tee" | "poster";
    size: string;
    lang: string;
    quantity: number;
    price: number;
    title: string;
    variant: string;
    image: string;
  }

  const STORAGE_KEY = "fb-cart";
  const root = document.getElementById("fb-cart");
  if (root) {
    const dl = root.dataset.locale;
    const locale = dl === "fa" ? "fa" : "en";
    const backdrop = root.querySelector<HTMLElement>("[data-cart-backdrop]");
    const itemsWrap = root.querySelector<HTMLElement>("[data-cart-items]");
    const emptyMsg = root.querySelector<HTMLElement>("[data-cart-empty]");
    const footer = root.querySelector<HTMLElement>("[data-cart-footer]");
    const subtotalEl = root.querySelector<HTMLElement>("[data-cart-subtotal]");
    const errorEl = root.querySelector<HTMLElement>("[data-cart-error]");
    const checkoutBtn = root.querySelector<HTMLButtonElement>("[data-cart-checkout]");
    const closers = root.querySelectorAll<HTMLElement>("[data-cart-close]");

    const keyOf = (i: Pick<CartItem, "sku" | "format" | "size" | "lang">) =>
      `${i.sku}~${i.format}~${i.size}~${i.lang ?? "en"}`;

    const load = (): CartItem[] => {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        const parsed = raw ? JSON.parse(raw) : [];
        return Array.isArray(parsed) ? (parsed as CartItem[]) : [];
      } catch {
        return [];
      }
    };

    let items: CartItem[] = load();

    const money = (n: number) => `$${n.toFixed(2)}`;
    const count = () => items.reduce((sum, i) => sum + i.quantity, 0);

    function save() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      document.dispatchEvent(
        new CustomEvent("fb-cart:change", { detail: { count: count() } }),
      );
    }

    function escapeHtml(s: string) {
      const div = document.createElement("div");
      div.textContent = s;
      return div.innerHTML;
    }

    function render() {
      if (!itemsWrap || !emptyMsg || !footer || !subtotalEl) return;
      const empty = items.length === 0;
      emptyMsg.hidden = !empty;
      footer.hidden = empty;
      itemsWrap.hidden = empty;

      if (!empty) {
        itemsWrap.innerHTML = items
          .map((i) => {
            const key = keyOf(i);
            const thumb = i.image
              ? `<img src="${escapeHtml(i.image)}" alt="" class="cart-thumb" />`
              : "";
            return `
              <div class="cart-row" data-row="${escapeHtml(key)}">
                ${thumb}
                <div class="cart-row-body">
                  <span class="cart-row-title font-display">${escapeHtml(i.title)}</span>
                  <span class="cart-row-variant">${escapeHtml(i.variant)}</span>
                  <div class="cart-row-foot">
                    <div class="cart-qty">
                      <button type="button" data-dec aria-label="-">&minus;</button>
                      <span data-qty>${i.quantity}</span>
                      <button type="button" data-inc aria-label="+">+</button>
                    </div>
                    <span class="cart-row-price">${money(i.price * i.quantity)}</span>
                  </div>
                </div>
              </div>`;
          })
          .join("");
        subtotalEl.textContent = money(
          items.reduce((sum, i) => sum + i.price * i.quantity, 0),
        );
      }
    }

    function setQty(key: string, delta: number) {
      const idx = items.findIndex((i) => keyOf(i) === key);
      if (idx === -1) return;
      const next = items[idx].quantity + delta;
      if (next <= 0) {
        items.splice(idx, 1);
      } else {
        items[idx].quantity = Math.min(20, next);
      }
      save();
      render();
    }

    function add(item: CartItem) {
      const key = keyOf(item);
      const existing = items.find((i) => keyOf(i) === key);
      if (existing) {
        existing.quantity = Math.min(20, existing.quantity + (item.quantity || 1));
      } else {
        items.push({ ...item, quantity: item.quantity || 1 });
      }
      save();
      render();
    }

    const open = () => {
      root.hidden = false;
      root.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      root.hidden = true;
      root.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      if (errorEl) errorEl.hidden = true;
    };

    itemsWrap?.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      const row = target.closest<HTMLElement>("[data-row]");
      if (!row) return;
      const key = row.dataset.row ?? "";
      if (target.closest("[data-inc]")) setQty(key, 1);
      else if (target.closest("[data-dec]")) setQty(key, -1);
    });

    checkoutBtn?.addEventListener("click", async () => {
      if (items.length === 0) return;
      if (errorEl) errorEl.hidden = true;
      checkoutBtn.disabled = true;
      try {
        const res = await fetch("/api/checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            locale,
            items: items.map((i) => ({
              sku: i.sku,
              format: i.format,
              size: i.size,
              lang: i.lang ?? "en",
              quantity: i.quantity,
            })),
          }),
        });
        if (!res.ok) throw new Error(`checkout failed: ${res.status}`);
        const data = (await res.json()) as { url?: string };
        if (!data.url) throw new Error("no checkout url");
        window.location.href = data.url;
      } catch {
        if (errorEl) errorEl.hidden = false;
        checkoutBtn.disabled = false;
      }
    });

    closers.forEach((el) => el.addEventListener("click", close));
    backdrop?.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !root.hidden) close();
    });

    document.addEventListener("fb-cart:add", (e) =>
      add((e as CustomEvent<CartItem>).detail),
    );
    document.addEventListener("fb-cart:open", open);
    document.addEventListener("fb-cart:close", close);
    document.addEventListener("fb-cart:toggle", () =>
      root.hidden ? open() : close(),
    );

    render();
    // Let the header badge initialise with the persisted count.
    document.dispatchEvent(
      new CustomEvent("fb-cart:change", { detail: { count: count() } }),
    );
  }
</script>

<style is:global>
  #fb-cart {
    position: fixed;
    inset: 0;
    z-index: 50;
  }
  #fb-cart[hidden] {
    display: none;
  }
  #fb-cart .cart-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-obsidian) 55%, transparent);
    backdrop-filter: blur(2px);
  }
  #fb-cart .cart-panel {
    position: absolute;
    inset-block: 0;
    inset-inline-end: 0;
    width: 100%;
    max-width: 27rem;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    box-shadow: var(--shadow-md);
  }
  #fb-cart .cart-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--line);
  }
  #fb-cart .cart-title {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--text);
  }
  #fb-cart .cart-x {
    background: none;
    border: 0;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
  }
  #fb-cart .cart-x:hover {
    color: var(--text);
  }
  #fb-cart .cart-items {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 1.25rem;
  }
  #fb-cart .cart-empty {
    flex: 1;
    padding: 3rem 1.25rem;
    text-align: center;
    color: var(--text-muted);
  }
  #fb-cart .cart-row {
    display: flex;
    gap: 0.85rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line);
  }
  #fb-cart .cart-thumb {
    width: 5rem;
    height: 6.5rem;
    flex: none;
    object-fit: contain;
    border-radius: 0.4rem;
    background: var(--surface-2);
  }
  #fb-cart .cart-row-body {
    display: flex;
    flex: 1;
    flex-direction: column;
  }
  #fb-cart .cart-row-title {
    font-size: 1rem;
    line-height: 1.3;
    color: var(--text);
  }
  #fb-cart .cart-row-variant {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  #fb-cart .cart-row-foot {
    margin-top: auto;
    padding-top: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  #fb-cart .cart-qty {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  #fb-cart .cart-qty button {
    width: 1.75rem;
    height: 1.75rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--line-strong);
    background: none;
    color: var(--text);
    cursor: pointer;
  }
  #fb-cart .cart-qty button:hover {
    border-color: var(--text);
  }
  #fb-cart .cart-qty [data-qty] {
    min-width: 1.5rem;
    text-align: center;
    font-size: 0.9rem;
  }
  #fb-cart .cart-row-price {
    font-size: 0.9rem;
    color: var(--text);
  }
  #fb-cart .cart-foot {
    border-top: 1px solid var(--line);
    padding: 1.25rem;
  }
  #fb-cart .cart-subtotal-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 1.1rem;
    color: var(--text);
  }
  #fb-cart .cart-ship {
    margin: 0.4rem 0 0;
    color: var(--text-muted);
  }
  #fb-cart .cart-err {
    margin: 0.75rem 0 0;
    color: var(--color-crimson);
  }
  #fb-cart .cart-checkout {
    margin-top: 1rem;
    width: 100%;
    padding: 0.85rem 1rem;
    border: 0;
    background: var(--color-emerald);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: filter 300ms var(--ease-editorial);
  }
  #fb-cart .cart-checkout:hover {
    filter: brightness(1.08);
  }
  #fb-cart .cart-checkout:disabled {
    opacity: 0.6;
    cursor: progress;
  }
  #fb-cart .cart-continue {
    margin-top: 0.6rem;
    width: 100%;
    cursor: pointer;
    background: none;
  }
  html[dir="rtl"] #fb-cart .cart-checkout,
  html[dir="rtl"] #fb-cart .cart-continue {
    text-transform: none;
    letter-spacing: 0.02em;
  }
</style>
