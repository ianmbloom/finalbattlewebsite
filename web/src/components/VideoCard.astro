---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import {
  CATEGORY_COLOR,
  formatDuration,
  getBlurb,
  getVariant,
  hasShareLinks,
  type VideoEntry,
} from "@/lib/videos";
import ShareBar from "./ShareBar.astro";

interface Props {
  entry: VideoEntry;
  lang: Locale;
}
const { entry, lang } = Astro.props;
const t = useTranslations(lang);

const variant = getVariant(entry, lang)!;
const href = localizedPath(`/videos/${entry.id}`, lang);
const duration = formatDuration(variant.durationSeconds);
const categoryLabel = t(`category.${entry.data.category}` as const);
const blurb = getBlurb(variant);
const catColor = CATEGORY_COLOR[entry.data.category];
const hasPlatforms = hasShareLinks(variant.platforms);
---

<article class="card" data-category={entry.data.category} style={`--cat:${catColor}`}>
  <a class="card-link" href={href} aria-label={variant.title}>
    <div class="thumb">
      {
        variant.thumbnailUrl ? (
          <img
            src={variant.thumbnailUrl}
            alt={variant.title}
            loading="lazy"
            decoding="async"
            width="270"
            height="480"
          />
        ) : (
          <span class="thumb-fallback label">9:16</span>
        )
      }
      <span class="play" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M8 5v14l11-7z" />
        </svg>
      </span>
      {duration && <span class="duration">{duration}</span>}
    </div>

    <div class="meta">
      <span class="label cat"><span class="keyline" aria-hidden="true"></span>{categoryLabel}</span>
      <h3 class="title font-display">{variant.title}</h3>
      {blurb && <p class="blurb">{blurb}</p>}
    </div>
  </a>

  {
    hasPlatforms && (
      <div class="card-share">
        <span class="card-share-label label">{t("promote.share")}</span>
        <ShareBar title={variant.title} platforms={variant.platforms} lang={lang} compact />
      </div>
    )
  }
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: transparent;
    border: none;
  }
  .card-link {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .card-share {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0 0.25rem;
  }
  .card-share-label {
    color: var(--text-muted);
    font-size: 0.62rem;
  }
  .thumb {
    position: relative;
    display: block;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    background: var(--color-ink);
    border-radius: 1rem;
    box-shadow: var(--shadow-sm);
    transform-origin: center bottom;
    transition:
      transform 350ms var(--ease-editorial),
      box-shadow 350ms var(--ease-editorial);
  }
  .card:hover .thumb {
    transform: scale(1.04);
    box-shadow: var(--shadow-md);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }
  .thumb-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-sand);
  }
  .play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-cream) 90%, transparent);
    border-radius: 999px;
    box-shadow: var(--shadow-sm);
    opacity: 0;
    transform: scale(0.85);
    transition:
      opacity 300ms var(--ease-editorial),
      transform 300ms var(--ease-editorial);
  }
  .play svg {
    margin-inline-start: 2px;
  }
  .card:hover .play {
    opacity: 1;
    transform: scale(1);
  }
  .duration {
    position: absolute;
    inset-block-end: 0.6rem;
    inset-inline-end: 0.6rem;
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-obsidian) 68%, transparent);
    border-radius: 2px;
    backdrop-filter: blur(2px);
  }
  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0 0.25rem 0.5rem;
  }
  .cat {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.66rem;
    font-weight: 600;
    color: var(--cat);
  }
  .keyline {
    width: 1.5rem;
    height: 2px;
    background: var(--cat);
    flex: none;
  }
  .title {
    margin: 0;
    font-weight: 600;
    font-size: 1.2rem;
    line-height: 1.2;
    color: var(--text);
    transition: color 300ms var(--ease-editorial);
  }
  .card:hover .title {
    color: var(--color-emerald);
  }
  .blurb {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
