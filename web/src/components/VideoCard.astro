---
import { SITE_URL, type Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import {
  formatDuration,
  getBlurb,
  getVariant,
  hasShareLinks,
  isComingSoon,
  type VideoEntry,
} from "@/lib/videos";
import RepostMenu from "./RepostMenu.astro";

interface Props {
  entry: VideoEntry;
  lang: Locale;
}
const { entry, lang } = Astro.props;
const t = useTranslations(lang);

const variant = getVariant(entry, lang)!;
const href = localizedPath(`/videos/${entry.id}`, lang);
const pageUrl = new URL(href, SITE_URL).href;
const duration = formatDuration(variant.durationSeconds);
const blurb = getBlurb(variant);
const hasPlatforms = hasShareLinks(variant.platforms);
const comingSoon = isComingSoon(entry);
---

<article
  class:list={["card", { "card--soon": comingSoon }]}
  data-category={entry.data.category}
>
  {
    comingSoon ? (
      <div
        class="card-link card-soon"
        role="button"
        tabindex="0"
        data-coming-soon
        data-film-title={variant.title}
        aria-label={`${variant.title}: ${t("video.comingSoon")}`}
      >
        <div class="thumb">
          {variant.thumbnailUrl ? (
            <img
              src={variant.thumbnailUrl}
              alt={variant.title}
              loading="lazy"
              decoding="async"
              width="270"
              height="480"
            />
          ) : (
            <span class="thumb-fallback label">9:16</span>
          )}
          <span class="soon-veil" aria-hidden="true" />
          <span class="soon-badge label">{t("video.comingSoon")}</span>
          <span class="soon-cta">
            {t("video.comingSoon.cta")}
            <svg viewBox="0 0 24 24" fill="none" width="16" height="16">
              <path
                d="M5 12h14M13 6l6 6-6 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
        </div>

        <div class="meta">
          <h3 class="title font-display">{variant.title}</h3>
          {blurb && <p class="blurb">{blurb}</p>}
        </div>
      </div>
    ) : (
      <a class="card-link" href={href} aria-label={variant.title}>
        <div class="thumb">
          {variant.thumbnailUrl ? (
            <img
              src={variant.thumbnailUrl}
              alt={variant.title}
              loading="lazy"
              decoding="async"
              width="270"
              height="480"
            />
          ) : (
            <span class="thumb-fallback label">9:16</span>
          )}
          <span class="play" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
          {duration && <span class="duration">{duration}</span>}
        </div>

        <div class="meta">
          <h3 class="title font-display">{variant.title}</h3>
          {blurb && <p class="blurb">{blurb}</p>}
        </div>
      </a>
    )
  }

  {
    hasPlatforms && !comingSoon && (
      <div class="card-share">
        <span class="card-share-label label">{t("promote.share")}</span>
        <RepostMenu
          title={variant.title}
          platforms={variant.platforms}
          pageUrl={pageUrl}
          lang={lang}
          compact
        />
      </div>
    )
  }
</article>

<script>
  // Coming-soon cards have no player to open — a click (or keyboard activation)
  // surfaces the email-capture popup so the visitor can be first to hear.
  const fire = (el: HTMLElement) => {
    document.dispatchEvent(
      new CustomEvent("fb-film:coming-soon", {
        detail: { title: el.dataset.filmTitle ?? "" },
      }),
    );
  };

  document.querySelectorAll<HTMLElement>("[data-coming-soon]").forEach((el) => {
    el.addEventListener("click", () => fire(el));
    el.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        fire(el);
      }
    });
  });
</script>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: transparent;
    border: none;
  }
  .card-link {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .card-soon {
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .card-soon:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 4px;
    border-radius: 1rem;
  }
  .card-share {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0 0.25rem;
  }
  .card-share-label {
    color: var(--text-muted);
    font-size: 0.62rem;
  }
  .thumb {
    position: relative;
    display: block;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    background: var(--color-ink);
    border-radius: 1rem;
    box-shadow: var(--shadow-sm);
    transform-origin: center bottom;
    transition:
      transform 350ms var(--ease-editorial),
      box-shadow 350ms var(--ease-editorial);
  }
  .card:hover .thumb {
    transform: scale(1.04);
    box-shadow: var(--shadow-md);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }
  .thumb-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-sand);
  }
  .play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-cream) 90%, transparent);
    border-radius: 999px;
    box-shadow: var(--shadow-sm);
    opacity: 0;
    transform: scale(0.85);
    transition:
      opacity 300ms var(--ease-editorial),
      transform 300ms var(--ease-editorial);
  }
  .play svg {
    margin-inline-start: 2px;
  }
  .card:hover .play {
    opacity: 1;
    transform: scale(1);
  }
  .duration {
    position: absolute;
    inset-block-end: 0.6rem;
    inset-inline-end: 0.6rem;
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-obsidian) 68%, transparent);
    border-radius: 2px;
    backdrop-filter: blur(2px);
  }
  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0 0.25rem 0.5rem;
  }
  .title {
    margin: 0;
    font-weight: 600;
    font-size: 1.2rem;
    line-height: 1.2;
    color: var(--text);
    transition: color 300ms var(--ease-editorial);
  }
  .card:hover .title {
    color: var(--color-emerald);
  }
  .blurb {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Coming-soon teaser: dim the still, stamp a badge, and reveal an inviting
     CTA on hover/focus so the card reads as "not yet — but be first". */
  .card--soon .thumb img {
    filter: grayscale(0.35) brightness(0.72);
    transition: filter 350ms var(--ease-editorial);
  }
  .card--soon:hover .thumb img,
  .card-soon:focus-visible .thumb img {
    filter: grayscale(0) brightness(0.82);
  }
  .soon-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-obsidian) 78%, transparent),
      transparent 55%
    );
  }
  .soon-badge {
    position: absolute;
    inset-block-start: 0.6rem;
    inset-inline-start: 0.6rem;
    padding: 0.28rem 0.6rem;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-obsidian);
    background: var(--color-gold);
    border-radius: 2px;
    box-shadow: var(--shadow-sm);
  }
  .soon-cta {
    position: absolute;
    inset-block-end: 0.75rem;
    inset-inline-start: 0.75rem;
    inset-inline-end: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-cream);
    background: color-mix(in srgb, var(--color-emerald) 88%, transparent);
    border-radius: 4px;
    box-shadow: var(--shadow-sm);
    opacity: 0;
    transform: translateY(0.5rem);
    transition:
      opacity 300ms var(--ease-editorial),
      transform 300ms var(--ease-editorial);
  }
  .card--soon:hover .soon-cta,
  .card-soon:focus-visible .soon-cta {
    opacity: 1;
    transform: translateY(0);
  }
  .card--soon:hover .title {
    color: var(--color-gold);
  }
  @media (prefers-reduced-motion: reduce) {
    .card--soon .thumb img,
    .soon-cta {
      transition: none;
    }
  }
</style>
