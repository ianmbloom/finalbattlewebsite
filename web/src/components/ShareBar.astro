---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { shareablePlatforms } from "@/lib/videos";

interface Platforms {
  x?: string;
  instagram?: string;
  tiktok?: string;
  youtube?: string;
}

interface Props {
  title: string;
  platforms?: Platforms;
  lang: Locale;
  /** Compact icon-only mode used inside cards. */
  compact?: boolean;
}

const { title, lang, compact = false } = Astro.props;
const t = useTranslations(lang);
// Drop any platform link still set to a PLACEHOLDER post URL.
const platforms = shareablePlatforms(Astro.props.platforms);

// X intent points at the *native X post* (not our URL) so shares stay in X's
// ecosystem and feed the algorithm, per the distribution strategy.
const xIntent = platforms.x
  ? `https://twitter.com/intent/tweet?url=${encodeURIComponent(
      platforms.x,
    )}&text=${encodeURIComponent(`${title} #IranProsperity #FreeIran`)}`
  : null;

const shareUrl =
  platforms.x ||
  platforms.tiktok ||
  platforms.instagram ||
  platforms.youtube ||
  "";
---

<div class:list={["share-bar", { compact }]}>
  <button
    type="button"
    class="share-trigger label"
    data-share-url={shareUrl}
    data-share-title={title}
  >
    {t("share.button")}
  </button>
  {
    xIntent && (
      <a class="share-link label" href={xIntent} target="_blank" rel="noopener">
        {compact ? "X" : t("share.x")}
      </a>
    )
  }
  {
    platforms.tiktok && (
      <a
        class="share-link label"
        href={platforms.tiktok}
        target="_blank"
        rel="noopener"
      >
        {compact ? "TT" : t("share.tiktok")}
      </a>
    )
  }
  {
    platforms.instagram && (
      <a
        class="share-link label"
        href={platforms.instagram}
        target="_blank"
        rel="noopener"
      >
        {compact ? "IG" : t("share.instagram")}
      </a>
    )
  }
  {
    platforms.youtube && (
      <a
        class="share-link label"
        href={platforms.youtube}
        target="_blank"
        rel="noopener"
      >
        {compact ? "YT" : t("share.youtube")}
      </a>
    )
  }
</div>

<script>
  document
    .querySelectorAll<HTMLButtonElement>("[data-share-url]")
    .forEach((btn) => {
      btn.addEventListener("click", async () => {
        const url = btn.dataset.shareUrl;
        const title = btn.dataset.shareTitle ?? "";
        if (!url) return;
        if (navigator.share) {
          try {
            await navigator.share({ title, url });
          } catch {
            /* user dismissed the share sheet */
          }
        } else {
          await navigator.clipboard?.writeText(url);
          btn.dataset.copied = "true";
          setTimeout(() => delete btn.dataset.copied, 1500);
        }
      });
    });
</script>

<style>
  .share-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
  }
  .share-bar.compact {
    gap: 0.85rem;
  }
  .share-trigger {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    color: var(--text);
    transition: color 300ms var(--ease-editorial);
  }
  .share-trigger[data-copied="true"]::after {
    content: " ✓";
    color: var(--color-emerald);
  }
  .share-link {
    color: var(--text-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .share-trigger:hover,
  .share-link:hover {
    color: var(--color-emerald);
  }
</style>
