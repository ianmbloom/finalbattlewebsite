---
import type { Locale } from "@/consts";
import { TIP } from "@/config/tip";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang: Locale;
  /** Drop the donate buttons into a single emphasized band (used on /fund). */
  variant?: "band" | "inline";
  /** Render grayed-out and inert until Stripe checkout is configured. */
  disabled?: boolean;
}

const { lang, variant = "inline", disabled = false } = Astro.props;
const t = useTranslations(lang);

const kotletWord = lang === "fa" ? "کتلت" : "kotlets";
const price = (qty: number) => {
  const amount = (qty * TIP.unitAmount) / 100;
  if (lang === "fa") {
    return `${amount} دلار`;
  }
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: TIP.currency,
    maximumFractionDigits: 0,
  }).format(amount);
};
const currencySymbol = lang === "fa" ? "دلار" : "$";
---

<div class:list={["support-cta", variant, { "is-disabled": disabled }]} data-tip data-locale={lang}>
  <p class="tip-label">
    {t("support.donate.title")}
    {disabled && <span class="soon">{t("common.soon")}</span>}
  </p>
  <div class="actions" role="group" aria-label={t("support.donate.title")}>
    {
      TIP.quantities.map((qty) => {
        const label = `${qty} ${kotletWord}, ${price(qty)}`;
        return disabled ? (
          <span class="support-btn kotlet" aria-disabled="true">
            <span class="qty">{qty} {kotletWord}</span>
            <span class="amount">{price(qty)}</span>
          </span>
        ) : (
          <button
            type="button"
            class="support-btn kotlet"
            data-tip-qty={qty}
            aria-label={label}
          >
            <span class="qty">{qty} {kotletWord}</span>
            <span class="amount">{price(qty)}</span>
          </button>
        );
      })
    }
    {!disabled && (
      <button type="button" class="support-btn kotlet custom-kotlet" data-tip-custom-btn>
        <span class="qty">{t("support.donate.custom")}</span>
        <span class="custom-amount">
          <span class="custom-spacer" aria-hidden="true"></span>
          {lang !== "fa" && <span class="custom-currency">$</span>}
          <input
            type="number"
            class="custom-input"
            data-tip-custom
            dir="ltr"
            min="1"
            max={TIP.maxQuantity}
            placeholder="?"
            aria-label={t("support.donate.customPlaceholder")}
            onclick="event.stopPropagation()"
          />
          {lang === "fa" && <span class="custom-currency">دلار</span>}
          <span class="custom-arrow is-hidden" data-tip-custom-arrow>{lang === "fa" ? "←" : "→"}</span>
        </span>
      </button>
    )}
  </div>
  <p class="tip-error" data-tip-error hidden>{t("support.error")}</p>
  <p class="body">{t("support.donate.body")}</p>
</div>

<script define:vars={{ unitAmount: TIP.unitAmount }}>
  document.querySelectorAll<HTMLElement>("[data-tip]").forEach((root) => {
    if (root.dataset.tipBound === "1") return;
    root.dataset.tipBound = "1";

    const locale = root.dataset.locale ?? "en";
    const errorEl = root.querySelector<HTMLElement>("[data-tip-error]");
    const buttons = Array.from(
      root.querySelectorAll<HTMLButtonElement>("button[data-tip-qty]"),
    );
    const customBtn = root.querySelector<HTMLButtonElement>("[data-tip-custom-btn]");
    const customInput = root.querySelector<HTMLInputElement>("[data-tip-custom]");
    const customArrow = root.querySelector<HTMLElement>("[data-tip-custom-arrow]");

    let arrowTimeout: ReturnType<typeof setTimeout> | null = null;

    const setDisabled = (disabled: boolean) => {
      buttons.forEach((b) => (b.disabled = disabled));
      if (customBtn) customBtn.disabled = disabled;
      if (customInput) customInput.disabled = disabled;
    };

    const checkout = async (amount: number) => {
      setDisabled(true);
      if (errorEl) errorEl.hidden = true;
      try {
        const res = await fetch("/api/tip/create-checkout", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ locale, amount }),
        });
        if (!res.ok) throw new Error(String(res.status));
        const { url } = (await res.json()) as { url?: string };
        if (!url) throw new Error("no_url");
        window.location.assign(url);
      } catch {
        setDisabled(false);
        if (errorEl) errorEl.hidden = false;
      }
    };

    buttons.forEach((btn) => {
      const qty = Number(btn.dataset.tipQty);
      const amount = (qty * unitAmount) / 100;
      btn.addEventListener("click", () => checkout(amount));
    });

    const submitCustom = () => {
      if (!customInput) return;
      const amount = Math.min(500, Math.max(1, Math.floor(Number(customInput.value))));
      if (amount > 0) checkout(amount);
    };

    customBtn?.addEventListener("click", () => {
      if (!customInput) return;
      const val = customInput.value.trim();
      if (!val || Number(val) <= 0) {
        customInput.focus();
      } else {
        submitCustom();
      }
    });
    customInput?.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        submitCustom();
      }
    });

customInput?.addEventListener("input", () => {
      if (arrowTimeout) clearTimeout(arrowTimeout);
      customArrow?.classList.add("is-hidden");

      const val = customInput.value;
      if (val.length >= 2) {
        arrowTimeout = setTimeout(() => {
          customArrow?.classList.remove("is-hidden");
        }, 1000);
      }
    });
  });
</script>

<style>
  .support-cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .tip-label {
    margin: 0;
    max-width: 52ch;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--text);
  }
  .body {
    margin: 0;
    max-width: 52ch;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  .support-btn {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    min-width: 4.5rem;
    padding: 0.7rem 1.1rem;
    border-radius: 2px;
    font-family: var(--font-body);
    cursor: pointer;
    transition:
      transform 300ms var(--ease-editorial),
      box-shadow 300ms var(--ease-editorial),
      filter 300ms var(--ease-editorial);
  }
  .amount {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1;
  }
  .qty {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    opacity: 0.75;
  }
  .support-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    filter: brightness(1.05);
  }
  .kotlet {
    background: var(--color-canary);
    color: var(--color-ink);
    border: 0;
  }
  .support-btn:disabled {
    opacity: 0.45;
    cursor: wait;
    transform: none;
    box-shadow: none;
    filter: none;
  }
  .support-cta.band {
    align-items: flex-start;
  }
  .support-cta.is-disabled .support-btn {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }
  .tip-error {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-rose, #d66);
  }
  .tip-error[hidden] {
    display: none;
  }
  .soon {
    display: inline-block;
    margin-inline-start: 0.6rem;
    vertical-align: middle;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    color: var(--text-muted);
  }
  html[dir="rtl"] .soon {
    text-transform: none;
    letter-spacing: 0;
  }

  .custom-amount {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    height: 1.1rem;
    line-height: 1;
  }
  .custom-currency {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-ink);
  }
  html[dir="rtl"] .custom-currency {
    font-size: 0.9rem;
  }
  .custom-input {
    width: 2rem;
    height: 1.1rem;
    padding: 0;
    border: 0;
    background: transparent;
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1;
    color: var(--color-ink);
    text-align: left;
  }
  .custom-input::placeholder {
    color: color-mix(in srgb, var(--color-ink) 40%, transparent);
  }
  .custom-input:focus {
    outline: none;
  }
  .custom-input::-webkit-outer-spin-button,
  .custom-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .custom-input[type="number"] {
    -moz-appearance: textfield;
  }
  .custom-input:disabled {
    opacity: 0.5;
    cursor: wait;
  }
  .custom-spacer {
    width: 1rem;
    margin-inline-end: 0.3rem;
  }
  .custom-arrow {
    width: 1rem;
    margin-inline-start: 0.3rem;
    font-size: 1rem;
    color: var(--color-ink);
  }
  .custom-arrow.is-hidden {
    opacity: 0;
  }
</style>
