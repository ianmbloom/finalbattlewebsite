---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { type VideoVariant } from "@/lib/videos";

interface Props {
  variant: VideoVariant;
  lang: Locale;
  /** Absolute URL of this video's page, used for the Reddit submit intent. */
  pageUrl: string;
}
const { variant, lang, pageUrl } = Astro.props;
const t = useTranslations(lang);

// The share destinations, in display order. The native-post rows (X,
// Instagram, TikTok, YouTube, LinkedIn) link to the video's platform URLs so a
// repost stays on the original post; until a real (non-placeholder) URL is
// filled in, the row renders disabled with a "Soon" cue. Reddit has no single
// native post, so its row opens Reddit's submission form pre-filled with this
// video's own page URL + title and is always enabled.
const platforms = variant.platforms ?? {};
const isReal = (url?: string) => Boolean(url && !url.includes("PLACEHOLDER"));

const redditIntent = `https://www.reddit.com/submit?url=${encodeURIComponent(
  pageUrl,
)}&title=${encodeURIComponent(variant.title)}`;

const rows = [
  { key: "x", label: t("share.guide.x"), url: platforms.x },
  { key: "instagram", label: t("share.guide.instagram"), url: platforms.instagram },
  { key: "tiktok", label: t("share.guide.tiktok"), url: platforms.tiktok },
  { key: "youtube", label: t("share.guide.youtube"), url: platforms.youtube },
  { key: "linkedin", label: t("share.guide.linkedin"), url: platforms.linkedin },
  { key: "reddit", label: t("share.guide.reddit"), url: redditIntent },
];
---

<section class="share-guide">
  <span class="label guide-label">{t("share.guide.title")}</span>
  <p class="guide-hint">{t("share.guide.hint")}</p>
  <ul class="rows">
    {
      rows.map((row) => (
        <li class="row" data-platform={row.key}>
          {isReal(row.url) ? (
            <a class="row-link" href={row.url} target="_blank" rel="noopener">
              <span class="row-name">{row.label}</span>
              <span class="row-cue" aria-hidden="true">↗</span>
            </a>
          ) : (
            <span class="row-link is-disabled" aria-disabled="true">
              <span class="row-name">{row.label}</span>
              <span class="row-cue label soon">{t("common.soon")}</span>
            </span>
          )}
        </li>
      ))
    }
  </ul>
</section>

<style>
  .share-guide {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .guide-label {
    color: var(--text-muted);
  }
  .guide-hint {
    margin: 0;
    max-width: 46ch;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--text-muted);
  }
  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 1.5rem;
    row-gap: 0.35rem;
  }
  @media (min-width: 1100px) {
    .rows {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  .row-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.25rem 0;
    color: var(--text);
    transition: color 300ms var(--ease-editorial);
  }
  .row-name {
    font-size: 0.9rem;
    letter-spacing: 0.01em;
  }
  /* Enabled links catch a periodic gold glint — a subtle "twinkle" that keeps
     the share actions feeling alive. Each link is offset so they sparkle out
     of sync rather than all at once. */
  a.row-link .row-name {
    background-image: linear-gradient(
      110deg,
      var(--text) 0%,
      var(--text) 43%,
      var(--color-canary) 50%,
      var(--text) 57%,
      var(--text) 100%
    );
    background-size: 250% 100%;
    background-position: 150% 0;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: share-twinkle 5s var(--ease-editorial) infinite;
  }
  .row:nth-child(2) a.row-link .row-name {
    animation-delay: 0.8s;
  }
  .row:nth-child(3) a.row-link .row-name {
    animation-delay: 1.6s;
  }
  .row:nth-child(4) a.row-link .row-name {
    animation-delay: 2.4s;
  }
  .row:nth-child(5) a.row-link .row-name {
    animation-delay: 3.2s;
  }
  .row:nth-child(6) a.row-link .row-name {
    animation-delay: 4s;
  }
  @keyframes share-twinkle {
    0%,
    55% {
      background-position: 150% 0;
    }
    80%,
    100% {
      background-position: -50% 0;
    }
  }
  .row-cue {
    color: var(--text-muted);
    font-size: 0.8rem;
    transition: color 300ms var(--ease-editorial);
  }
  a.row-link:hover {
    color: var(--color-emerald);
  }
  /* On hover, stop the glint and paint the label solid emerald. */
  a.row-link:hover .row-name {
    animation: none;
    background: none;
    -webkit-text-fill-color: currentColor;
    color: currentColor;
  }
  a.row-link:hover .row-cue {
    color: var(--color-emerald);
  }
  @media (prefers-reduced-motion: reduce) {
    a.row-link .row-name {
      animation: none;
      background: none;
      -webkit-text-fill-color: currentColor;
      color: currentColor;
    }
  }
  .row-link.is-disabled {
    color: var(--text-muted);
    cursor: default;
  }
  .soon {
    color: var(--text-muted);
    font-size: 0.58rem;
  }
</style>
