---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import BusinessPattern from "./BusinessPattern.astro";

interface Props {
  lang: Locale;
  /** Show a button linking to the full library (off on the library page itself). */
  showCta?: boolean;
}
const { lang, showCta = true } = Astro.props;
const t = useTranslations(lang);
const videosHref = localizedPath("/videos", lang);
---

<section class="promote-band business-surface">
  <BusinessPattern />
  <div class="promote-inner">
    <h2 class="title font-display">{t("promote.title")}</h2>
    <p class="body">{t("promote.body")}</p>
    {showCta && <a class="btn-outline-on-bar cta" href={videosHref}>{t("promote.cta")}</a>}
  </div>
</section>

<style>
  .promote-band {
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
    border-block: 1px solid var(--bar-line);
  }
  .promote-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4rem) 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }
  .title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.1;
    color: var(--bar-text);
  }
  .body {
    margin: 0;
    max-width: 56ch;
    line-height: 1.6;
    color: var(--bar-muted);
  }
  .cta {
    margin-top: 0.5rem;
  }
</style>
