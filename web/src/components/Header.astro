---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import LangSwitcher from "./LangSwitcher.astro";
import Logo from "./Logo.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: localizedPath("/videos", lang), label: t("nav.videos") },
  { href: localizedPath("/about", lang), label: t("nav.about") },
];
const current = Astro.url.pathname.replace(/\/$/, "");
---

<header class="site-header">
  <a class="brand" href={localizedPath("/", lang)} aria-label={t("site.name")}>
    <span class="brand-mark"><Logo size={36} /></span>
    <span class="brand-text">
      <span class="brand-name font-logo">{t("site.name")}</span>
      <span class="brand-sub label">{t("site.subtitle")}</span>
    </span>
  </a>

  <nav class="primary" aria-label="Primary">
    {
      links.map((link) => (
        <a
          href={link.href}
          class:list={["nav-link", "label", { active: current === link.href.replace(/\/$/, "") }]}
        >
          {link.label}
        </a>
      ))
    }
    <LangSwitcher lang={lang} />
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .brand-mark {
    color: var(--color-gold);
    display: inline-flex;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-name {
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1;
    letter-spacing: 0.01em;
    color: var(--text);
  }
  .brand-sub {
    margin-top: 0.15rem;
    font-size: 0.62rem;
    color: var(--color-gold);
  }
  .primary {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-link {
    color: var(--text-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-gold);
  }
  @media (max-width: 640px) {
    .primary {
      gap: 1.25rem;
    }
    .brand-name {
      font-size: 1.1rem;
    }
  }
</style>
