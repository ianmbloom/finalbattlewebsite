---
import type { Locale } from "@/consts";
import { FEATURES } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import LangSwitcher from "./LangSwitcher.astro";
import Logo from "./Logo.astro";
import BusinessPattern from "./BusinessPattern.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: localizedPath("/videos", lang), label: t("nav.videos"), ready: true },
  { href: localizedPath("/support", lang), label: t("nav.support"), ready: true },
  { href: localizedPath("/about", lang), label: t("nav.about"), ready: true },
];
const current = Astro.url.pathname.replace(/\/$/, "");
---

<header class="site-header business-surface">
  <BusinessPattern posY="-120px" />
  <div class="bar-inner">
    <a class="brand" href={localizedPath("/", lang)} aria-label={t("site.name")}>
      <span class="brand-mark"><Logo size={44} /></span>
      <span class="brand-text">
        <span class="brand-name font-logo">{t("site.name")}</span>
        <span class="brand-sub label">{t("site.subtitle")}</span>
      </span>
    </a>

    <nav class="primary" aria-label="Primary">
      {
        links.map((link) =>
          link.ready ? (
            <a
              href={link.href}
              class:list={["nav-link", "label", { active: current === link.href.replace(/\/$/, "") }]}
            >
              {link.label}
            </a>
          ) : (
            <span class="nav-link label disabled" aria-disabled="true">
              {link.label}
              <span class="soon">{t("common.soon")}</span>
            </span>
          ),
        )
      }
      {
        FEATURES.shop && (
          <button type="button" class="nav-link label cart-btn" data-cart-toggle>
            {t("nav.cart")}
            <span class="cart-count" data-cart-count hidden>
              0
            </span>
          </button>
        )
      }
      <LangSwitcher lang={lang} />
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-cart-toggle]");
  const badge = document.querySelector<HTMLElement>("[data-cart-count]");
  toggle?.addEventListener("click", () =>
    document.dispatchEvent(new CustomEvent("fb-cart:toggle")),
  );
  document.addEventListener("fb-cart:change", (event) => {
    const count = (event as CustomEvent<{ count: number }>).detail?.count ?? 0;
    if (!badge) return;
    badge.textContent = String(count);
    badge.hidden = count === 0;
  });
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--bar-line);
  }
  .bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .brand-mark {
    color: var(--bar-accent);
    display: inline-flex;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-name {
    font-weight: 400;
    font-size: 1.4rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--bar-text);
  }
  html[dir="rtl"] .brand-name {
    text-transform: none;
    letter-spacing: 0;
  }
  .brand-sub {
    margin-top: 0.25rem;
    font-size: 0.6rem;
    color: var(--color-rose);
  }
  .primary {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-link {
    color: var(--bar-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--bar-accent);
  }
  .nav-link.disabled {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--bar-muted);
    opacity: 0.5;
    cursor: not-allowed;
  }
  .soon {
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    padding: 0.1rem 0.35rem;
    border: 1px solid var(--bar-line);
    border-radius: 999px;
    color: var(--bar-muted);
  }
  html[dir="rtl"] .soon {
    letter-spacing: 0;
  }
  .cart-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
  }
  .cart-count {
    display: inline-grid;
    place-items: center;
    min-width: 1.15rem;
    height: 1.15rem;
    padding: 0 0.3rem;
    border-radius: 999px;
    background: var(--bar-accent);
    color: var(--color-ink);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
  }
  @media (max-width: 640px) {
    .primary {
      gap: 1.25rem;
    }
    .brand-name {
      font-size: 1.1rem;
    }
  }
</style>
