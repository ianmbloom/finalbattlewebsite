---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import LangSwitcher from "./LangSwitcher.astro";
import Logo from "./Logo.astro";
import BusinessPattern from "./BusinessPattern.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: localizedPath("/videos", lang), label: t("nav.videos") },
  { href: localizedPath("/about", lang), label: t("nav.about") },
];
const current = Astro.url.pathname.replace(/\/$/, "");
---

<header class="site-header business-surface">
  <BusinessPattern posY="-120px" />
  <div class="bar-inner">
    <a class="brand" href={localizedPath("/", lang)} aria-label={t("site.name")}>
      <span class="brand-mark"><Logo size={44} /></span>
      <span class="brand-text">
        <span class="brand-name font-logo">{t("site.name")}</span>
        <span class="brand-sub label">{t("site.subtitle")}</span>
      </span>
    </a>

    <nav class="primary" aria-label="Primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={["nav-link", "label", { active: current === link.href.replace(/\/$/, "") }]}
          >
            {link.label}
          </a>
        ))
      }
      <LangSwitcher lang={lang} />
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--bar-line);
  }
  .bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.4rem 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .brand-mark {
    color: var(--bar-accent);
    display: inline-flex;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-name {
    font-weight: 400;
    font-size: 1.4rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--bar-text);
  }
  html[dir="rtl"] .brand-name {
    text-transform: none;
    letter-spacing: 0;
  }
  .brand-sub {
    margin-top: 0.25rem;
    font-size: 0.6rem;
    color: var(--color-rose);
  }
  .primary {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-link {
    color: var(--bar-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--bar-accent);
  }
  @media (max-width: 640px) {
    .primary {
      gap: 1.25rem;
    }
    .brand-name {
      font-size: 1.1rem;
    }
  }
</style>
