---
/**
 * Engagement-triggered email popup. Watches how many distinct videos a visitor
 * has opened (tracked in localStorage) and, once they have watched more than
 * one, surfaces an email-capture modal — the moment intent is clearest. This is
 * the only involuntary popup: the Launch mechanic is opt-in on the video page.
 * All decisions are client-side; nothing renders until the threshold is met,
 * and the ask is capped and cooled-down so it never becomes a nag.
 */
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import Newsletter from "@/components/Newsletter.astro";
import BusinessPattern from "@/components/BusinessPattern.astro";

interface Props {
  lang: Locale;
  /** Slug of the video on this page, if any — counted toward the trigger. */
  trackVideoId?: string;
}

const { lang, trackVideoId } = Astro.props;
const t = useTranslations(lang);
---

<div
  id="fb-engage"
  data-locale={lang}
  data-video-slug={trackVideoId}
  data-soon-title={t("popup.soon.title")}
  data-soon-body={t("popup.soon.body")}
  hidden
  aria-hidden="true"
>
  <div data-engage-backdrop class="engage-backdrop"></div>

  <aside
    data-engage-panel="email"
    class="engage-panel business-surface"
    role="dialog"
    aria-modal="true"
    aria-labelledby="engage-email-title"
    hidden
  >
    <BusinessPattern />
    <button type="button" data-engage-close class="engage-x" aria-label={t("popup.close")}>
      <span aria-hidden="true">&times;</span>
    </button>
    <div class="engage-inner">
      <h2 id="engage-email-title" class="engage-title font-display">
        {t("popup.email.title")}
      </h2>
      <p class="engage-body">{t("popup.email.body")}</p>
      <Newsletter lang={lang} compact idSuffix="popup" />
    </div>
  </aside>
</div>

<script>
  interface EngageState {
    videos: string[];
    emailDone: boolean;
    emailDismissedAt: number | null;
    emailShownCount: number;
  }

  const STORAGE_KEY = "fb-engage";
  const SHOWN_KEY = "fb-engage-shown"; // at most one popup per session

  const DAY = 24 * 60 * 60 * 1000;
  const EMAIL_MIN_VIDEOS = 2;
  const EMAIL_MAX_SHOWS = 3;
  const EMAIL_COOLDOWN = 7 * DAY;

  const root = document.getElementById("fb-engage");
  if (root) {
    const defaults: EngageState = {
      videos: [],
      emailDone: false,
      emailDismissedAt: null,
      emailShownCount: 0,
    };

    const load = (): EngageState => {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        const parsed = raw ? JSON.parse(raw) : {};
        return {
          ...defaults,
          ...(parsed as Partial<EngageState>),
          videos: Array.isArray(parsed?.videos) ? parsed.videos : [],
        };
      } catch {
        return { ...defaults };
      }
    };

    const state = load();

    const save = () => {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      } catch {
        /* private mode / quota — degrade to a nag-free experience */
      }
    };

    // Record the video on this page toward the engagement threshold.
    const slug = root.dataset.videoSlug;
    if (slug && !state.videos.includes(slug)) {
      state.videos.push(slug);
      save();
    }

    const alreadyShown = () => {
      try {
        return sessionStorage.getItem(SHOWN_KEY) === "1";
      } catch {
        return false;
      }
    };
    const markShown = () => {
      try {
        sessionStorage.setItem(SHOWN_KEY, "1");
      } catch {
        /* ignore */
      }
    };

    const cooled = (at: number | null, cooldown: number) =>
      at == null || Date.now() - at > cooldown;

    const emailEligible = () =>
      !state.emailDone &&
      state.videos.length >= EMAIL_MIN_VIDEOS &&
      state.emailShownCount < EMAIL_MAX_SHOWS &&
      cooled(state.emailDismissedAt, EMAIL_COOLDOWN);

    const backdrop = root.querySelector<HTMLElement>("[data-engage-backdrop]");
    const panel = root.querySelector<HTMLElement>('[data-engage-panel="email"]');
    const titleEl = panel?.querySelector<HTMLElement>("#engage-email-title");
    const bodyEl = panel?.querySelector<HTMLElement>(".engage-body");

    // Default copy, so a forced (coming-soon) show can be reset back to the
    // standard engagement ask if the same panel is reused later.
    const defaultTitle = titleEl?.textContent ?? "";
    const defaultBody = bodyEl?.textContent ?? "";

    let open = false;
    let lastFocus: HTMLElement | null = null;

    interface ShowOptions {
      /** User-initiated (e.g. a coming-soon click): always honored, uncapped. */
      forced?: boolean;
      title?: string;
      body?: string;
    }

    const show = ({ forced = false, title, body }: ShowOptions = {}) => {
      if (!panel || open) return;
      open = true;
      lastFocus = document.activeElement as HTMLElement | null;
      markShown();

      if (titleEl) titleEl.textContent = title || defaultTitle;
      if (bodyEl) bodyEl.textContent = body || defaultBody;

      root.hidden = false;
      root.setAttribute("aria-hidden", "false");
      panel.hidden = false;
      document.body.style.overflow = "hidden";

      // Only the automatic engagement path counts against the show cap.
      if (!forced) {
        state.emailShownCount += 1;
        save();
      }

      const focusTarget = panel.querySelector<HTMLElement>("input[type=email]");
      window.requestAnimationFrame(() => focusTarget?.focus());
    };

    const close = (converted = false) => {
      if (!converted) {
        state.emailDismissedAt = Date.now();
        save();
      }
      if (panel) panel.hidden = true;
      root.hidden = true;
      root.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      open = false;
      lastFocus?.focus?.();
    };

    root
      .querySelectorAll<HTMLElement>("[data-engage-close], [data-engage-dismiss]")
      .forEach((el) => el.addEventListener("click", () => close()));
    backdrop?.addEventListener("click", () => close());
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !root.hidden) close();
    });

    // A confirmed signup (from any newsletter form) settles the email ask.
    document.addEventListener("fb-newsletter:success", () => {
      state.emailDone = true;
      save();
      if (open) window.setTimeout(() => close(true), 1400);
    });

    // Surface the ask exactly as a video wraps up — the moment attention is
    // released — rather than on an arbitrary timer that interrupts the watch.
    // The VideoPlayer emits this a beat before the final frame.
    const maybeShow = () => {
      if (open || alreadyShown() || !emailEligible()) return;
      show();
    };
    document.addEventListener("fb-video:ending", maybeShow, { once: true });

    // A click on a "coming soon" film is explicit intent — always open the
    // popup with copy naming the film, so they can be first to hear about it.
    document.addEventListener("fb-film:coming-soon", (event) => {
      const film =
        (event as CustomEvent<{ title?: string }>).detail?.title ?? "";
      const soonTitle = root.dataset.soonTitle || defaultTitle;
      const soonBody = (root.dataset.soonBody || defaultBody).replace(
        "{film}",
        () => film,
      );
      show({ forced: true, title: soonTitle, body: soonBody });
    });
  }
</script>

<style is:global>
  #fb-engage {
    position: fixed;
    inset: 0;
    z-index: 60;
  }
  #fb-engage[hidden] {
    display: none;
  }
  #fb-engage .engage-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-obsidian) 60%, transparent);
    backdrop-filter: blur(2px);
    animation: engage-fade 300ms var(--ease-editorial);
  }
  #fb-engage .engage-panel {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    margin-inline: auto;
    width: 100%;
    max-width: 32rem;
    border-radius: 6px 6px 0 0;
    box-shadow: var(--shadow-md);
    animation: engage-rise 320ms var(--ease-editorial);
  }
  #fb-engage .engage-panel[hidden] {
    display: none;
  }
  @media (min-width: 640px) {
    #fb-engage .engage-panel {
      inset-block: 50% auto;
      transform: translateY(-50%);
      border-radius: 6px;
      animation: engage-pop 320ms var(--ease-editorial);
    }
  }
  #fb-engage .engage-inner {
    padding: clamp(1.75rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  #fb-engage .engage-title {
    margin: 0;
    font-weight: 300;
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    line-height: 1.1;
    color: var(--bar-text);
  }
  #fb-engage .engage-body {
    margin: 0;
    max-width: 46ch;
    color: var(--bar-muted);
    line-height: 1.6;
  }
  #fb-engage .engage-x {
    position: absolute;
    inset-block-start: 0.35rem;
    inset-inline-end: 0.5rem;
    z-index: 2;
    background: none;
    border: 0;
    font-size: 1.7rem;
    line-height: 1;
    color: var(--bar-muted);
    cursor: pointer;
    padding: 0.35rem 0.6rem;
  }
  #fb-engage .engage-x:hover {
    color: var(--bar-text);
  }
  #fb-engage .engage-dismiss {
    align-self: flex-start;
    background: none;
    border: 0;
    padding: 0;
    color: var(--bar-muted);
    cursor: pointer;
    transition: color 300ms var(--ease-editorial);
  }
  #fb-engage .engage-dismiss:hover {
    color: var(--bar-accent);
  }
  @keyframes engage-fade {
    from {
      opacity: 0;
    }
  }
  @keyframes engage-rise {
    from {
      transform: translateY(100%);
    }
  }
  @keyframes engage-pop {
    from {
      opacity: 0;
      transform: translateY(-50%) scale(0.96);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #fb-engage .engage-backdrop,
    #fb-engage .engage-panel {
      animation: none;
    }
  }
</style>
