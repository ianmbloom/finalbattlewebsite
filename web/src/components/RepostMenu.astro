---
import type { Locale } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import { shareablePlatforms, withUtm, encodeHex } from "@/lib/videos";

interface Platforms {
  x?: string;
  instagram?: string;
  youtube?: string;
  linkedin?: string;
}

interface Props {
  title: string;
  platforms?: Platforms;
  /** Absolute URL of this video's page on our site. */
  pageUrl: string;
  lang: Locale;
  /** Compact trigger used inside cards. */
  compact?: boolean;
  /** Video slug for fetching confirmed URLs from database. */
  videoSlug?: string;
  /** Raw video path for download (e.g. /videos/foo.mp4), before CDN resolution. */
  videoPath?: string;
}

const { title, pageUrl, lang, compact = false, videoSlug, videoPath } = Astro.props;
const downloadFilename = videoPath ? `${title.replace(/[^a-zA-Z0-9\u0600-\u06FF\s]/g, "").replace(/\s+/g, "-")}.mp4` : "";
const t = useTranslations(lang);

// Native-post links stay on their platform (no UTM — they leave our domain).
// Only real (non-placeholder) links render.
const platforms = shareablePlatforms(Astro.props.platforms);
// Native-post URLs are hex-encoded so the handles (which still carry the
// nation's name) never appear literally in the HTML; RepostMenu's script
// decodes them into real hrefs at runtime.
const nativeRows = [
  { key: "x", label: t("share.x"), url: platforms.x },
  { key: "instagram", label: t("share.instagram"), url: platforms.instagram },
  { key: "youtube", label: t("share.youtube"), url: platforms.youtube },
  { key: "linkedin", label: t("share.linkedin"), url: platforms.linkedin },
]
  .filter((row): row is { key: string; label: string; url: string } =>
    Boolean(row.url),
  )
  .map((row) => ({ key: row.key, label: row.label, enc: encodeHex(row.url) }));

// Platform labels for dynamically loaded links
const platformLabels: Record<string, string> = {
  x: t("share.x"),
  youtube: t("share.youtube"),
  linkedin: t("share.linkedin"),
  instagram: t("share.instagram"),
};

// Telegram + Copy share the site page URL (tagged) — Telegram renders the video
// inline from our Open Graph metadata, and both are attributable via UTM.
const telegramUrl = withUtm(pageUrl, "telegram");
const copyUrl = withUtm(pageUrl, "copy");
const telegramIntent = `https://t.me/share/url?url=${encodeURIComponent(
  telegramUrl,
)}&text=${encodeURIComponent(title)}`;

// Unique ids so the single hoisted script can pair each trigger to its overlay.
const uid = `repost-${Math.random().toString(36).slice(2, 9)}`;
const titleId = `${uid}-title`;
---

<div 
  class:list={["repost", { compact }]}
  data-video-slug={videoSlug}
  data-video-lang={lang}
  data-platform-labels={JSON.stringify(platformLabels)}
>
  <button
    type="button"
    class="repost-trigger"
    data-repost-open
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls={uid}
  >
    <span class="repost-trigger-label">
      {compact ? t("share.repostShort") : t("share.repost")}
    </span>
    <span class="repost-trigger-cue" aria-hidden="true">↗</span>
  </button>

  <div
    id={uid}
    class="repost-overlay"
    data-repost-overlay
    hidden
  >
    <div class="repost-backdrop" data-repost-close></div>
    <div class="repost-panel" role="dialog" aria-modal="true" aria-labelledby={titleId}>
      <div class="repost-head">
        <h2 id={titleId} class="repost-title font-display">
          {t("share.repostTitle")}
        </h2>
        <button
          type="button"
          class="repost-close"
          data-repost-close
          aria-label={t("share.close")}
        >
          &times;
        </button>
      </div>

      <ul class="repost-list">
        {
          nativeRows.map((row) => (
            <li>
              <a
                class="repost-link"
                data-href={row.enc}
                data-platform={row.key}
                target="_blank"
                rel="noopener nofollow"
              >
                <span class="repost-name">{row.label}</span>
                <span class="repost-cue" aria-hidden="true">
                  ↗
                </span>
              </a>
            </li>
          ))
        }
        <li>
          <a
            class="repost-link"
            href={telegramIntent}
            target="_blank"
            rel="noopener"
          >
            <span class="repost-name">{t("share.telegram")}</span>
            <span class="repost-cue" aria-hidden="true">↗</span>
          </a>
        </li>
        {videoPath && (
          <li class="download-item">
            <button
              type="button"
              class="repost-link download-link"
              data-download-btn
              data-video-path={videoPath}
              data-filename={downloadFilename}
            >
              <span class="repost-name download-label">{t("video.download")}</span>
              <span class="repost-cue" aria-hidden="true">↓</span>
            </button>
          </li>
        )}
      </ul>

      <button
        type="button"
        class="repost-copy label"
        data-repost-copy
        data-copy-url={copyUrl}
      >
        <span class="copy-idle">{t("share.copyLink")}</span>
        <span class="copy-done">{t("share.copied")}</span>
      </button>
    </div>
  </div>
</div>

<script>
  interface RepostWindow extends Window {
    __repostMenuInit?: boolean;
  }
  const w = window as RepostWindow;

  if (!w.__repostMenuInit) {
    w.__repostMenuInit = true;

    // Rebuild native-post hrefs from their hex-encoded form so the handles are
    // absent from the served HTML but the links still work for real visitors.
    document
      .querySelectorAll<HTMLAnchorElement>(".repost-link[data-href]")
      .forEach((link) => {
        const pairs = link.dataset.href?.match(/../g);
        if (!pairs) return;
        link.href = new TextDecoder().decode(
          new Uint8Array(pairs.map((h) => parseInt(h, 16))),
        );
      });

    // Fetch confirmed platform URLs from the database and add/update links
    document.querySelectorAll<HTMLElement>(".repost[data-video-slug]").forEach(async (repost) => {
      const slug = repost.dataset.videoSlug;
      const lang = repost.dataset.videoLang || "en";
      const labels = JSON.parse(repost.dataset.platformLabels || "{}");
      
      if (!slug) return;
      
      try {
        const res = await fetch(`/api/video-platforms?slug=${encodeURIComponent(slug)}&lang=${encodeURIComponent(lang)}`);
        if (!res.ok) return;
        
        const data = await res.json();
        const platforms = data.platforms || {};
        
        const list = repost.querySelector(".repost-list");
        if (!list) return;
        
        // Check which platforms we already have links for
        const existingPlatforms = new Set<string>();
        list.querySelectorAll(".repost-link[data-platform]").forEach((link) => {
          existingPlatforms.add((link as HTMLElement).dataset.platform || "");
        });
        
        // Add new links for confirmed platforms not already in the list
        // (skip TikTok - no longer supported)
        // Find the Telegram link to insert platform links before it
        const telegramItem = list.querySelector('a[href^="https://t.me/"]')?.closest("li");
        
        for (const [platform, url] of Object.entries(platforms)) {
          if (existingPlatforms.has(platform) || !url || platform === "tiktok") continue;
          
          const label = labels[platform] || platform;
          const li = document.createElement("li");
          li.innerHTML = `
            <a class="repost-link" href="${url}" target="_blank" rel="noopener nofollow" data-platform="${platform}">
              <span class="repost-name">${label}</span>
              <span class="repost-cue" aria-hidden="true">↗</span>
            </a>
          `;
          // Insert before Telegram so platform links come first
          if (telegramItem) {
            list.insertBefore(li, telegramItem);
          } else {
            list.appendChild(li);
          }
        }
        
        // Also update any existing links that might have placeholder URLs
        for (const [platform, url] of Object.entries(platforms)) {
          if (!url) continue;
          const existingLink = list.querySelector(`.repost-link[data-platform="${platform}"]`) as HTMLAnchorElement;
          if (existingLink && !existingLink.href.startsWith("http")) {
            existingLink.href = url as string;
          }
        }
      } catch (e) {
        console.error("Failed to fetch video platforms:", e);
      }
    });

    let lastTrigger: HTMLElement | null = null;

    const overlayFor = (id: string | null): HTMLElement | null =>
      id ? document.getElementById(id) : null;

    const openOverlay = (overlay: HTMLElement) => {
      overlay.hidden = false;
      const trigger = document.querySelector<HTMLElement>(
        `[aria-controls="${overlay.id}"]`,
      );
      lastTrigger = trigger;
      trigger?.setAttribute("aria-expanded", "true");
      overlay.querySelector<HTMLElement>("a, button")?.focus();
      document.addEventListener("keydown", onKeydown);
    };

    const closeOverlay = (overlay: HTMLElement) => {
      overlay.hidden = true;
      document
        .querySelector<HTMLElement>(`[aria-controls="${overlay.id}"]`)
        ?.setAttribute("aria-expanded", "false");
      document.removeEventListener("keydown", onKeydown);
      lastTrigger?.focus();
      lastTrigger = null;
    };

    const onKeydown = (e: KeyboardEvent) => {
      if (e.key !== "Escape") return;
      document
        .querySelectorAll<HTMLElement>("[data-repost-overlay]:not([hidden])")
        .forEach(closeOverlay);
    };

    document.addEventListener("click", async (e) => {
      const target = e.target as HTMLElement;

      const openBtn = target.closest<HTMLElement>("[data-repost-open]");
      if (openBtn) {
        const overlay = overlayFor(openBtn.getAttribute("aria-controls"));
        if (overlay) openOverlay(overlay);
        return;
      }

      const closeBtn = target.closest<HTMLElement>("[data-repost-close]");
      if (closeBtn) {
        const overlay = closeBtn.closest<HTMLElement>("[data-repost-overlay]");
        if (overlay) closeOverlay(overlay);
        return;
      }

      const copyBtn = target.closest<HTMLElement>("[data-repost-copy]");
      if (copyBtn) {
        const url = copyBtn.dataset.copyUrl;
        if (!url) return;
        navigator.clipboard?.writeText(url);
        copyBtn.dataset.copied = "true";
        setTimeout(() => {
          delete copyBtn.dataset.copied;
        }, 1500);
      }

      const downloadBtn = target.closest<HTMLElement>("[data-download-btn]");
      if (downloadBtn) {
        const videoPath = downloadBtn.dataset.videoPath;
        const filename = downloadBtn.dataset.filename || "video.mp4";
        if (!videoPath) return;

        // Use the download proxy endpoint which adds Content-Disposition header
        const downloadUrl = `/api/download?path=${encodeURIComponent(videoPath)}&filename=${encodeURIComponent(filename)}`;
        
        // Create a hidden link and click it to trigger download
        const a = document.createElement("a");
        a.href = downloadUrl;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      }
    });
  }
</script>

<style>
  .repost {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Understated twinkling link with an up-right arrow (matches .launch-trigger). */
  .repost-trigger {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    color: var(--text);
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    transition: color 300ms var(--ease-editorial);
  }
  .repost-trigger-label {
    background-image: linear-gradient(
      110deg,
      var(--text) 0%,
      var(--text) 43%,
      var(--color-canary) 50%,
      var(--text) 57%,
      var(--text) 100%
    );
    background-size: 250% 100%;
    background-position: 150% 0;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    /* Offset from the Launch twinkle so the two links sparkle out of sync. */
    animation: repost-twinkle 5s var(--ease-editorial) infinite;
    animation-delay: 2.5s;
  }
  .repost-trigger-cue {
    color: var(--text-muted);
    font-size: 0.8rem;
    transition: color 300ms var(--ease-editorial);
  }
  .repost-trigger:hover {
    color: var(--color-emerald);
  }
  .repost-trigger:hover .repost-trigger-label {
    animation: none;
    background: none;
    -webkit-text-fill-color: currentColor;
    color: currentColor;
  }
  .repost-trigger:hover .repost-trigger-cue {
    color: var(--color-emerald);
  }
  @keyframes repost-twinkle {
    0%,
    55% {
      background-position: 150% 0;
    }
    80%,
    100% {
      background-position: -50% 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .repost-trigger-label {
      animation: none;
      background: none;
      -webkit-text-fill-color: currentColor;
      color: currentColor;
    }
  }

  /* Quieter, calm text on cards: no twinkle, no arrow. */
  .repost.compact .repost-trigger {
    color: var(--text-muted);
    font-size: 0.62rem;
  }
  .repost.compact .repost-trigger-cue {
    display: none;
  }
  .repost.compact .repost-trigger-label {
    animation: none;
    background: none;
    -webkit-text-fill-color: currentColor;
    color: currentColor;
  }
  .repost.compact .repost-trigger:hover,
  .repost.compact .repost-trigger:hover .repost-trigger-label {
    color: var(--color-emerald);
  }

  .repost-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .repost-overlay[hidden] {
    display: none;
  }
  .repost-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-obsidian) 72%, transparent);
    backdrop-filter: blur(3px);
  }
  .repost-panel {
    position: relative;
    width: min(24rem, 100%);
    background: var(--bg);
    border: 1px solid var(--border, color-mix(in srgb, var(--text) 12%, transparent));
    border-radius: 1rem;
    box-shadow: var(--shadow-md);
    padding: 1.5rem 1.5rem 1.25rem;
  }

  .repost-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .repost-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--text);
  }
  .repost-close {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--text-muted);
    transition: color 300ms var(--ease-editorial);
  }
  .repost-close:hover {
    color: var(--color-emerald);
  }

  .repost-list {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .repost-list :global(li) {
    display: flex;
    width: 100%;
  }
  .repost-list :global(.repost-link) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 0.6rem 0;
    color: var(--text);
    border-bottom: 1px solid
      color-mix(in srgb, var(--text) 8%, transparent);
    transition: color 300ms var(--ease-editorial);
  }
  .repost-list :global(li:last-child .repost-link) {
    border-bottom: 0;
  }
  .repost-list :global(.repost-name) {
    font-size: 0.95rem;
    letter-spacing: 0.01em;
  }
  .repost-list :global(.repost-cue) {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .repost-list :global(.repost-link:hover),
  .repost-list :global(.repost-link:hover .repost-cue) {
    color: var(--color-emerald);
  }

  /* Download button at the bottom of the list */
  .download-item {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
  }
  .download-link {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    font-family: inherit;
    cursor: pointer;
  }
  .download-link .repost-cue {
    font-size: 1rem;
    font-weight: 600;
  }
  .download-link[disabled] {
    cursor: wait;
    opacity: 0.6;
  }

  /* Quiet, secondary copy-link affordance. */
  .repost-copy {
    background: none;
    border: 0;
    padding: 0.25rem 0;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.72rem;
    transition: color 300ms var(--ease-editorial);
  }
  .repost-copy:hover {
    color: var(--text);
  }
  .copy-done {
    display: none;
    color: var(--color-emerald);
  }
  .repost-copy[data-copied="true"] .copy-idle {
    display: none;
  }
  .repost-copy[data-copied="true"] .copy-done {
    display: inline;
  }
</style>
