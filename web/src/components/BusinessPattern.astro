---
/**
 * Consistent canary filigree on emerald business surfaces (nav, footer, CTAs).
 * Defaults match the footer treatment the user approved.
 */
import PatternBackground from "./PatternBackground.astro";

interface Props {
  opacity?: number;
  posY?: string;
}

const { opacity = 0.09, posY = "0" } = Astro.props;
---

<PatternBackground color="canary" opacity={opacity} posY={posY} />
