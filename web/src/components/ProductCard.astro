---
import type { Locale } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import { localized, type ProductEntry } from "@/lib/products";

interface Props {
  lang: Locale;
  entry: ProductEntry;
}

const { lang, entry } = Astro.props;
const t = useTranslations(lang);
const { data } = entry;
const href = localizedPath(`/products/${entry.id}`, lang);
const name = localized(data.name, lang);
// Lead with the T-shirt price: it's the headline product.
const fromPrice = data.formats.tee.price;
---

<article class="product-card">
  <a class="thumb" href={href} aria-label={name}>
    <img src={data.image} alt={name} width="768" height="1152" loading="lazy" />
  </a>
  <div class="meta">
    <a class="name font-display" href={href}>{name}</a>
    <p class="price label">{t("product.from")} ${fromPrice.toFixed(2)}</p>
  </div>
</article>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .thumb {
    display: block;
    overflow: hidden;
    aspect-ratio: 2 / 3;
    border-radius: 1rem;
    background: var(--surface-2);
    box-shadow: var(--shadow-sm);
    transition:
      transform 350ms var(--ease-editorial),
      box-shadow 350ms var(--ease-editorial);
  }
  .product-card:hover .thumb {
    transform: scale(1.03);
    box-shadow: var(--shadow-md);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0 0.25rem;
  }
  .name {
    font-size: 1.1rem;
    line-height: 1.25;
    color: var(--text);
    transition: color 300ms var(--ease-editorial);
  }
  .product-card:hover .name {
    color: var(--color-emerald);
  }
  .price {
    margin: 0;
    color: var(--text-muted);
  }
</style>
