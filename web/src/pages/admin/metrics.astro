---
/**
 * Metrics admin page - view platform performance data.
 * LOCAL-ONLY: API endpoints guard with ADMIN_ENABLED; pages always render.
 */
import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Metrics">
  <div class="metrics-admin">
    <section class="controls">
      <div class="filter-group">
        <label for="platform-select">Platform:</label>
        <select id="platform-select">
          <option value="all">All Platforms</option>
          <option value="x">X (Twitter)</option>
          <option value="youtube">YouTube</option>
          <option value="linkedin">LinkedIn</option>
          <option value="instagram">Instagram</option>
        </select>
      </div>
      
      <div class="filter-group">
        <label for="language-select">Language:</label>
        <select id="language-select">
          <option value="all">All Languages</option>
          <option value="en">English</option>
          <option value="fa">Farsi</option>
        </select>
      </div>
      
      <button class="btn btn-primary" id="refresh-btn">
        🔄 Refresh Metrics
      </button>
    </section>

    <section class="summary-section">
      <h2>Summary</h2>
      <div class="stat-grid" id="summary-stats">
        <div class="stat-card">
          <span class="stat-label">Total Views</span>
          <span class="stat-value" id="total-views">—</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Total Likes</span>
          <span class="stat-value" id="total-likes">—</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Total Comments</span>
          <span class="stat-value" id="total-comments">—</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Total Shares</span>
          <span class="stat-value" id="total-shares">—</span>
        </div>
      </div>
    </section>

    <section class="comparison-section">
      <h2>EN vs FA Performance</h2>
      <div class="comparison-grid" id="comparison-grid">
        <p class="empty-state">Select filters and refresh to load data.</p>
      </div>
    </section>

    <section class="table-section">
      <h2>Detailed Metrics</h2>
      <div class="table-container">
        <table id="metrics-table">
          <thead>
            <tr>
              <th>Video</th>
              <th>Platform</th>
              <th>Language</th>
              <th>Date</th>
              <th>Views</th>
              <th>Likes</th>
              <th>Comments</th>
              <th>Shares</th>
            </tr>
          </thead>
          <tbody id="metrics-tbody">
            <tr>
              <td colspan="8" class="empty-state">No metrics data yet.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="manual-entry-section">
      <h2>Manual Entry (LinkedIn)</h2>
      <p class="section-desc">For platforms without automated metric ingestion, enter data manually.</p>
      <form class="manual-form" id="manual-form">
        <div class="form-row">
          <div class="form-group">
            <label for="manual-video">Video Slug:</label>
            <input type="text" id="manual-video" required placeholder="e.g., returning-to-democracy" />
          </div>
          <div class="form-group">
            <label for="manual-platform">Platform:</label>
            <select id="manual-platform" required>
              <option value="linkedin">LinkedIn</option>
              <option value="instagram">Instagram</option>
            </select>
          </div>
          <div class="form-group">
            <label for="manual-language">Language:</label>
            <select id="manual-language" required>
              <option value="en">English</option>
              <option value="fa">Farsi</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="manual-views">Views:</label>
            <input type="number" id="manual-views" min="0" value="0" />
          </div>
          <div class="form-group">
            <label for="manual-likes">Likes:</label>
            <input type="number" id="manual-likes" min="0" value="0" />
          </div>
          <div class="form-group">
            <label for="manual-comments">Comments:</label>
            <input type="number" id="manual-comments" min="0" value="0" />
          </div>
          <div class="form-group">
            <label for="manual-shares">Shares:</label>
            <input type="number" id="manual-shares" min="0" value="0" />
          </div>
        </div>
        <button type="submit" class="btn btn-primary">💾 Save Metrics</button>
      </form>
    </section>
  </div>
</AdminLayout>

<script>
  const refreshBtn = document.getElementById("refresh-btn") as HTMLButtonElement;
  const manualForm = document.getElementById("manual-form") as HTMLFormElement;
  
  refreshBtn?.addEventListener("click", async () => {
    refreshBtn.disabled = true;
    refreshBtn.textContent = "⏳ Refreshing...";
    
    try {
      const res = await fetch("/api/admin/metrics/refresh", { method: "POST" });
      if (res.ok) {
        const data = await res.json();
        alert(`Metrics refreshed. ${data.rowsWritten ?? 0} rows updated.`);
        loadMetrics();
      } else {
        const err = await res.json();
        alert(`Error: ${err.error || "Failed to refresh metrics"}`);
      }
    } catch (e) {
      alert("Network error. Please try again.");
    } finally {
      refreshBtn.disabled = false;
      refreshBtn.textContent = "🔄 Refresh Metrics";
    }
  });
  
  manualForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    
    const videoSlug = (document.getElementById("manual-video") as HTMLInputElement).value;
    const platform = (document.getElementById("manual-platform") as HTMLSelectElement).value;
    const language = (document.getElementById("manual-language") as HTMLSelectElement).value;
    const views = parseInt((document.getElementById("manual-views") as HTMLInputElement).value) || 0;
    const likes = parseInt((document.getElementById("manual-likes") as HTMLInputElement).value) || 0;
    const comments = parseInt((document.getElementById("manual-comments") as HTMLInputElement).value) || 0;
    const shares = parseInt((document.getElementById("manual-shares") as HTMLInputElement).value) || 0;
    
    try {
      const res = await fetch("/api/admin/metrics/manual", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ videoSlug, platform, language, views, likes, comments, shares }),
      });
      
      if (res.ok) {
        alert("Metrics saved!");
        loadMetrics();
      } else {
        const err = await res.json();
        alert(`Error: ${err.error || "Failed to save metrics"}`);
      }
    } catch (e) {
      alert("Network error. Please try again.");
    }
  });
  
  async function loadMetrics() {
    // TODO: Implement metrics loading
    console.log("Loading metrics...");
  }
  
  loadMetrics();
</script>

<style>
  .metrics-admin {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .controls {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-group label {
    font-size: 0.875rem;
    color: var(--admin-muted);
  }

  .filter-group select {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: 0.375rem;
    padding: 0.5rem 1rem;
    color: var(--admin-text);
  }

  .summary-section,
  .comparison-section,
  .table-section,
  .manual-entry-section {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: 0.5rem;
    padding: 1.5rem;
  }

  .summary-section h2,
  .comparison-section h2,
  .table-section h2,
  .manual-entry-section h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 1rem;
  }

  .section-desc {
    font-size: 0.875rem;
    color: var(--admin-muted);
    margin: 0 0 1rem;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
  }

  .stat-card {
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 0.375rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--admin-muted);
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 600;
  }

  .table-container {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    padding: 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--admin-border);
  }

  th {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--admin-muted);
    text-transform: uppercase;
  }

  .manual-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.75rem;
    color: var(--admin-muted);
  }

  .form-group input,
  .form-group select {
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
    color: var(--admin-text);
    font-size: 0.875rem;
  }

  .empty-state {
    color: var(--admin-muted);
    text-align: center;
    padding: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-primary {
    background: var(--admin-accent);
    color: white;
  }
</style>
