---
/**
 * Newsletter admin page - draft and send bilingual newsletters.
 * LOCAL-ONLY: API endpoints guard with ADMIN_ENABLED; pages always render.
 */
import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Newsletter">
  <div class="newsletter-admin">
    <section class="controls">
      <div class="language-selector">
        <label for="lang-select">Newsletter Language:</label>
        <select id="lang-select">
          <option value="en" selected>English</option>
          <option value="fa">فارسی (Farsi)</option>
        </select>
      </div>
      
      <div class="stats" id="stats">
        <span class="stat">
          <strong id="subscriber-count">—</strong> subscribers
        </span>
        <span class="stat">
          <strong id="draft-count">—</strong> drafts
        </span>
      </div>
    </section>

    <section class="draft-section">
      <h2>Create New Draft</h2>
      <div class="draft-form">
        <div class="form-group">
          <label for="draft-subject">Subject Line:</label>
          <input 
            type="text" 
            id="draft-subject" 
            placeholder="Enter subject line..."
          />
        </div>
        
        <div class="form-group">
          <label for="draft-prompt">AI Prompt (optional):</label>
          <textarea 
            id="draft-prompt" 
            rows="3"
            placeholder="Describe what you want in the newsletter, or leave blank for auto-generation..."
          ></textarea>
        </div>
        
        <button class="btn btn-primary" id="generate-btn">
          🤖 Generate Draft with AI
        </button>
      </div>
    </section>

    <section class="drafts-section">
      <h2>Drafts</h2>
      <div class="drafts-list" id="drafts-list">
        <p class="empty-state">Loading drafts...</p>
      </div>
    </section>

    <section class="preview-section" id="preview-section" hidden>
      <h2>Preview</h2>
      <div class="preview-controls">
        <button class="btn btn-secondary" id="edit-btn">✏️ Edit</button>
        <button class="btn btn-primary" id="approve-btn">✓ Approve</button>
        <button class="btn btn-danger" id="send-btn" disabled>📤 Send to Subscribers</button>
      </div>
      <div class="preview-frame">
        <iframe id="preview-iframe" title="Newsletter Preview"></iframe>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  const langSelect = document.getElementById("lang-select") as HTMLSelectElement;
  const subscriberCount = document.getElementById("subscriber-count");
  const draftCount = document.getElementById("draft-count");
  const draftsList = document.getElementById("drafts-list");
  const previewSection = document.getElementById("preview-section");
  const previewIframe = document.getElementById("preview-iframe") as HTMLIFrameElement;
  const generateBtn = document.getElementById("generate-btn") as HTMLButtonElement;
  const approveBtn = document.getElementById("approve-btn") as HTMLButtonElement;
  const sendBtn = document.getElementById("send-btn") as HTMLButtonElement;
  
  let currentDraftId: number | null = null;
  
  async function loadStats() {
    const lang = langSelect.value;
    try {
      const res = await fetch(`/api/admin/newsletter/stats?lang=${lang}`);
      if (res.ok) {
        const data = await res.json();
        if (subscriberCount) subscriberCount.textContent = data.subscribers ?? "0";
        if (draftCount) draftCount.textContent = data.drafts ?? "0";
      }
    } catch (e) {
      console.error("Failed to load stats:", e);
    }
  }
  
  async function loadDrafts() {
    const lang = langSelect.value;
    if (!draftsList) return;
    
    try {
      const res = await fetch(`/api/admin/newsletter/drafts?lang=${lang}`);
      if (res.ok) {
        const data = await res.json();
        if (data.drafts && data.drafts.length > 0) {
          draftsList.innerHTML = data.drafts.map((d: any) => `
            <div class="draft-card" data-id="${d.id}">
              <div class="draft-header">
                <span class="draft-subject">${d.subject || "(No subject)"}</span>
                <span class="draft-status status-${d.status}">${d.status}</span>
              </div>
              <div class="draft-meta">
                Created: ${new Date(d.created_at).toLocaleString()}
                ${d.sent_at ? ` | Sent: ${new Date(d.sent_at).toLocaleString()}` : ""}
              </div>
              <div class="draft-actions">
                <button class="btn btn-secondary preview-draft-btn" data-id="${d.id}">Preview</button>
                ${d.status === "draft" ? `<button class="btn btn-danger delete-draft-btn" data-id="${d.id}">Delete</button>` : ""}
              </div>
            </div>
          `).join("");
          
          draftsList.querySelectorAll(".preview-draft-btn").forEach(btn => {
            btn.addEventListener("click", () => previewDraft(Number((btn as HTMLElement).dataset.id)));
          });
          
          draftsList.querySelectorAll(".delete-draft-btn").forEach(btn => {
            btn.addEventListener("click", () => deleteDraft(Number((btn as HTMLElement).dataset.id)));
          });
        } else {
          draftsList.innerHTML = `<p class="empty-state">No drafts yet. Generate one above.</p>`;
        }
      }
    } catch (e) {
      console.error("Failed to load drafts:", e);
      draftsList.innerHTML = `<p class="empty-state">Failed to load drafts.</p>`;
    }
  }
  
  async function previewDraft(id: number) {
    currentDraftId = id;
    try {
      const res = await fetch(`/api/admin/newsletter/preview?id=${id}`);
      if (res.ok) {
        const data = await res.json();
        if (previewIframe && data.html) {
          previewIframe.srcdoc = data.html;
          previewSection?.removeAttribute("hidden");
          
          if (approveBtn) approveBtn.disabled = data.status === "approved" || data.status === "sent";
          if (sendBtn) sendBtn.disabled = data.status !== "approved";
        }
      }
    } catch (e) {
      console.error("Failed to preview draft:", e);
    }
  }
  
  async function deleteDraft(id: number) {
    if (!confirm("Delete this draft?")) return;
    try {
      const res = await fetch(`/api/admin/newsletter/delete?id=${id}`, { method: "POST" });
      if (res.ok) {
        loadDrafts();
        loadStats();
        if (currentDraftId === id) {
          previewSection?.setAttribute("hidden", "");
          currentDraftId = null;
        }
      }
    } catch (e) {
      console.error("Failed to delete draft:", e);
    }
  }
  
  generateBtn?.addEventListener("click", async () => {
    const lang = langSelect.value;
    const subject = (document.getElementById("draft-subject") as HTMLInputElement).value;
    const prompt = (document.getElementById("draft-prompt") as HTMLTextAreaElement).value;
    
    generateBtn.disabled = true;
    generateBtn.textContent = "⏳ Generating...";
    
    try {
      const res = await fetch("/api/admin/newsletter/draft", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ language: lang, subject, prompt }),
      });
      
      if (res.ok) {
        const data = await res.json();
        loadDrafts();
        loadStats();
        if (data.id) previewDraft(data.id);
      } else {
        const err = await res.json();
        alert(`Error: ${err.error || "Failed to generate draft"}`);
      }
    } catch (e) {
      alert("Network error. Please try again.");
    } finally {
      generateBtn.disabled = false;
      generateBtn.textContent = "🤖 Generate Draft with AI";
    }
  });
  
  approveBtn?.addEventListener("click", async () => {
    if (!currentDraftId) return;
    try {
      const res = await fetch(`/api/admin/newsletter/approve?id=${currentDraftId}`, { method: "POST" });
      if (res.ok) {
        loadDrafts();
        if (sendBtn) sendBtn.disabled = false;
        if (approveBtn) approveBtn.disabled = true;
      }
    } catch (e) {
      console.error("Failed to approve draft:", e);
    }
  });
  
  sendBtn?.addEventListener("click", async () => {
    if (!currentDraftId) return;
    if (!confirm("Send this newsletter to all subscribers? This cannot be undone.")) return;
    
    sendBtn.disabled = true;
    sendBtn.textContent = "📤 Sending...";
    
    try {
      const res = await fetch(`/api/admin/newsletter/send?id=${currentDraftId}`, { method: "POST" });
      if (res.ok) {
        const data = await res.json();
        alert(`Newsletter sent to ${data.sent ?? 0} subscribers!`);
        loadDrafts();
        loadStats();
      } else {
        const err = await res.json();
        alert(`Error: ${err.error || "Failed to send newsletter"}`);
      }
    } catch (e) {
      alert("Network error. Please try again.");
    } finally {
      sendBtn.textContent = "📤 Send to Subscribers";
    }
  });
  
  langSelect?.addEventListener("change", () => {
    loadStats();
    loadDrafts();
    previewSection?.setAttribute("hidden", "");
    currentDraftId = null;
  });
  
  loadStats();
  loadDrafts();
</script>

<style>
  .newsletter-admin {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .language-selector {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .language-selector label {
    font-weight: 500;
  }

  .language-selector select {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: 0.375rem;
    padding: 0.5rem 1rem;
    color: var(--admin-text);
    font-size: 1rem;
  }

  .stats {
    display: flex;
    gap: 1.5rem;
  }

  .stat {
    font-size: 0.875rem;
    color: var(--admin-muted);
  }

  .stat strong {
    color: var(--admin-text);
  }

  section h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 1rem;
  }

  .draft-section,
  .drafts-section,
  .preview-section {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: 0.5rem;
    padding: 1.5rem;
  }

  .draft-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.875rem;
    color: var(--admin-muted);
  }

  .form-group input,
  .form-group textarea {
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 0.375rem;
    padding: 0.75rem;
    color: var(--admin-text);
    font-size: 1rem;
    font-family: inherit;
  }

  .form-group textarea {
    resize: vertical;
  }

  .drafts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .draft-card {
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 0.375rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .draft-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .draft-subject {
    font-weight: 500;
  }

  .draft-status {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    text-transform: uppercase;
  }

  .status-draft {
    background: var(--admin-warning);
    color: black;
  }

  .status-approved {
    background: #3b82f6;
    color: white;
  }

  .status-sent {
    background: var(--admin-success);
    color: black;
  }

  .draft-meta {
    font-size: 0.75rem;
    color: var(--admin-muted);
  }

  .draft-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .empty-state {
    color: var(--admin-muted);
    text-align: center;
    padding: 2rem;
  }

  .preview-controls {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .preview-frame {
    background: white;
    border-radius: 0.375rem;
    overflow: hidden;
  }

  .preview-frame iframe {
    width: 100%;
    height: 600px;
    border: none;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s;
  }

  .btn:hover:not(:disabled) {
    opacity: 0.9;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-primary {
    background: var(--admin-accent);
    color: white;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: var(--admin-text);
  }

  .btn-danger {
    background: #dc2626;
    color: white;
  }
</style>
