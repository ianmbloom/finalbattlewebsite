---
import type { GetStaticPaths } from "astro";
import { getPlayableVideosForLocale } from "@/lib/videos";
import VideoDetailView from "@/components/views/VideoDetailView.astro";

export const getStaticPaths = (async () => {
  const videos = await getPlayableVideosForLocale("fa");
  return videos.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
---

<VideoDetailView entry={entry} lang="fa" />
