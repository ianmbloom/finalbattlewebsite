# Cloudflare Pages response headers.
# https://developers.cloudflare.com/pages/configuration/headers/

# Astro emits content-hashed assets that are safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Thumbnails use stable filenames and are updated frequently.
# Short TTL with stale-while-revalidate for good performance + timely updates.
/videos/thumbs/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Sensible security defaults for every HTML response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
