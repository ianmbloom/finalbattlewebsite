# Origin for self-hosted video files (Cloudflare R2 public bucket / custom
# domain). Set this in the Cloudflare Pages project settings for production so
# videos load from R2 — the large media files are never committed to git.
#
#   PUBLIC_VIDEO_BASE_URL=https://videos.finalbattleiran.org
#
# Leave it unset locally: `npm run dev` serves the files from public/videos/
# directly. A `videoSrc` that is already an absolute URL is used as-is and
# ignores this base.
PUBLIC_VIDEO_BASE_URL=
