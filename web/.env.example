# Cloudflare Stream — used to embed the bilingual video players
CLOUDFLARE_STREAM_TOKEN=        # Cloudflare Stream API token
CLOUDFLARE_ACCOUNT_ID=          # Your CF account ID
CLOUDFLARE_R2_BUCKET_NAME=      # e.g. "finalbattleiran-videos"

# The customer subdomain from the Cloudflare Stream dashboard
# (looks like customer-xxxxxxxx). Used to build iframe embed URLs.
PUBLIC_STREAM_CUSTOMER_SUBDOMAIN=customer-XXXX
