# Copy to `.env` for local dev and set the real values in the Cloudflare Pages
# project (Settings > Variables / Secrets). Never commit real values.
#
# Note: Pages Functions read these from the Pages environment (or `.dev.vars`
# for local `wrangler pages dev`), not from `.env`. `.env` is only used by the
# Astro build for PUBLIC_* / build-time values.

# --- Public (safe to expose in the built client) ---
# Origin for self-hosted video files (Cloudflare R2 public bucket).
PUBLIC_VIDEO_BASE_URL=https://videos.finalbattle.video

# --- Server-only secrets (Pages env vars / Functions) ---
STRIPE_SECRET_KEY=                # Stripe secret key (sk_live_... / sk_test_...)
STRIPE_WEBHOOK_SECRET=            # Signing secret for the /api/stripe-webhook endpoint (whsec_...)
SHIPPING_FLAT_CENTS=800           # Flat per-cart shipping (cents). Default 800 = $8.00.
STRIPE_AUTOMATIC_TAX=false        # "true" enables Stripe Tax (requires tax registrations in Stripe).

PRINTIFY_API_TOKEN=               # Printify personal access token (fulfillment)
PRINTIFY_SHOP_ID=                 # Printify shop id
PRINTIFY_SEND_TO_PRODUCTION=false # "true" auto-sends orders to production; default leaves them as drafts to review.
